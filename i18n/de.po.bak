#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:75
msgid "Enter a list of algebraic equations or inequalities"
msgstr "Gib eine Liste von Gleichungen oder Ungleichungen mit Termen an"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:76
msgid ""
"Enter a list of equations or inequalities, separated by commas.  Example: "
"y=3x^2+1, 2+x+y=3"
msgstr ""
"Geben Sie eine Komma-separierte Liste von Gleichungen oder Ungleichungen "
"ein. Beispiel: y=3x^2+1, 2+x+y=3"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:91
msgid "Enter an algebraic equation or inequality"
msgstr "Geben Sie eine Gleichung oder Ungleichung ein"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:92
msgid ""
"Enter your answer as an equation or inequality.  Example: y=3x^2+1, 2+x+y=3"
msgstr ""
"Geben Sie Ihre Antwort als Gleichung oder Ungleichung ein. Beuspiel: "
"y=3x^2+1, 2+x+y=3"

#: assess2/questions/answerboxes/MatchingAnswerBox.php:69
msgid "$questions and $matchlist should have the same number of entries"
msgstr "$questions und $matchlist sollten dieselbe Anzahl von Einträgen haben"

#: assess2/questions/answerboxes/MatrixAnswerBox.php:60
msgid ""
"Enter each element of the matrix as a complex number in a+bj form.  Example: "
"-3-4j"
msgstr ""
"Geben Sie jedes Element der Matrix als komplexe Zahl in der Form a+bj ein. "
"Beispiel: -3-4j"

#: assess2/questions/answerboxes/MatrixAnswerBox.php:62
msgid ""
"Enter each element of the matrix as a complex number in a+bi form.  Example: "
"-3-4i"
msgstr ""
"Geben Sie jedes Element der Matrix als komplexe Zahl in der Form a+bi ein. "
"Beispiel: -3-4i"

#: assess2/questions/answerboxes/MatrixAnswerBox.php:66
msgid "Enter each element of the matrix as number (like 5, -3, 2.2)"
msgstr "Geben Sie die Elemente der Matrix als Zahl ein (wie 5,-3,2.2)"

#: assess2/questions/answerboxes/MatrixAnswerBox.php:146
#: assess2/questions/answerboxes/MatrixAnswerBox.php:154
msgid ""
"Enter your answer as a matrix filled with complex numbers in a+bj form, like "
"[(2,3+j),(1-j,j)]"
msgstr ""
"Geben Sie Ihre Antwort als Matrix mit komplexen Zahlen der Form a+bj ein, "
"wie [(2,3+j),(1-j,j)]"

#: assess2/questions/answerboxes/MatrixAnswerBox.php:148
#: assess2/questions/answerboxes/MatrixAnswerBox.php:156
msgid ""
"Enter your answer as a matrix filled with complex numbers in a+bi form, like "
"[(2,3+i),(1-i,i)]"
msgstr ""
"Geben Sie Ihre Antwort als Matrix mit komplexen Zahlen der Form a+bi ein, "
"wie [(2,3+i),(1-i,i)]"

