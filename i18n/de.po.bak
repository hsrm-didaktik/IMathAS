msgstr "Dies ist eine globale Kurs-Vorlage"

#: admin/forms.php:1028 admin/forms.php:1026 admin/forms.php:1058
msgid "Mark as self-enroll course"
msgstr "Kurs erlaubt Selbst-Registrierung"

