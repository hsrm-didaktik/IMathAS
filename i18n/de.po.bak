#: admin/forms.php:1195
msgid "Mark as guest-access course"
msgstr "Kurs erlaubt Gast-Anmeldung ohne Passwort als 'guest'"

#: admin/forms.php:1058 admin/forms.php:1056 admin/forms.php:1088
#: admin/forms.php:1089 admin/forms.php:1092 admin/forms.php:1132
