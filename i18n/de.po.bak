#: assess2/questions/answerboxes/CalculatedMatrixAnswerBox.php:120
#: assess2/questions/answerboxes/StringAnswerBox.php:58
#: assess2/questions/answerboxes/CalculatedMatrixAnswerBox.php:143
#: assess2/questions/answerboxes/StringAnswerBox.php:65
#: assess2/questions/answerboxes/CalculatedMatrixAnswerBox.php:151
msgid "Enter your answer as a matrix"
msgstr "Geben Sie Ihre Antwort als Matrix ein"

#: assess2/questions/answerboxes/CalculatedMatrixAnswerBox.php:123
#: assess2/questions/answerboxes/StringAnswerBox.php:64
#: assess2/questions/answerboxes/CalculatedMatrixAnswerBox.php:121
#: assess2/questions/answerboxes/StringAnswerBox.php:59
