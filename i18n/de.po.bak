#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:66
#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:78
msgid "Enter a list of algebraic equations"
msgstr "Geben Sie eine Liste von algebraischen Gleichungen ein"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:67
#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:79
msgid ""
"Enter a list of equations, separated by commas.  Example: y=3x^2+1, 2+x+y=3"
msgstr ""
"Geben Sie eine Liste von Gleichungen ein, die durch Kommas getrennt werden. "
"Beispiel: y=3x^2+1, 2+x+y=3"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:69
#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:82
msgid "Enter a list of algebraic inequalities"
msgstr "Geben Sie eine Liste von algebraischen Ungleichungen ein"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:70
#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:83
msgid ""
"Enter a list of inequalities, separated by commas.  Example: y<3x^2+1, 2+x"
"+y>=3"
msgstr ""
"Geben Sie eine Liste von Ungleichungen ein, die durch Kommas getrennt "
"werden. Beispiel: y<3x^2+1, 2+x+y>=3"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:72
#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:85
msgid "Enter a list of algebraic expressions"
msgstr "Geben Sie eine Liste von Termen ein"

#: assess2/questions/answerboxes/FunctionExpressionAnswerBox.php:73
