#: course/report-a11y.php:52 course/report-a11y.php:76
msgid "Potential issue: [AB] in textonimage used without readerlabel"
msgstr "Mögliches Problem: [AB] in textonimage ohne readerlabel verwendet"

#: course/report-a11y.php:56 course/report-a11y.php:80
msgid "Potential issue: question may use jsxgraph; check for accessible alt"
msgstr ""
"Mögliches Problem: Die Frage verwendet möglicherweise jsxgraph; erwägen Sie "
"eine barrierefreie Alternative als alt"

#: course/report-a11y.php:60 course/report-a11y.php:84
msgid "Potential issue: question may use geogebra; check for accessible alt"
