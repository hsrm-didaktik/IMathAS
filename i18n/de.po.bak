#: assess2/questions/answerboxes/CalculatedMatrixAnswerBox.php:152
msgid ", like [(2,3,4),(1,4,5)]"
msgstr ", wie [(2,3,4),(1,4,5)]"

#: assess2/questions/answerboxes/MatrixAnswerBox.php:125
#: assess2/questions/answerboxes/MatrixAnswerBox.php:127
#: assess2/questions/answerboxes/MatrixAnswerBox.php:126
#: assess2/questions/answerboxes/MatrixAnswerBox.php:152
#: assess2/questions/answerboxes/MatrixAnswerBox.php:160
msgid "Enter a matrix of integer or decimal numbers"
msgstr "Geben Sie eine Matrix von ganzen Zahlen oder Dezimalzahlen ein"

#: assess2/questions/answerboxes/MatrixAnswerBox.php:126
#: assess2/questions/answerboxes/MatrixAnswerBox.php:128
#: assess2/questions/answerboxes/MatrixAnswerBox.php:127
#: assess2/questions/answerboxes/MatrixAnswerBox.php:153
#: assess2/questions/answerboxes/MatrixAnswerBox.php:161
msgid ""
"Enter your answer as a matrix filled with integer or decimal numbers, like "
"[(2,3,4),(3,4,5)]"
msgstr ""
"Geben Sie Ihre Antwort als Matrix mit ganzen Zahlen oder Dezimalzahlen ein, "
"wie [(2,3,4),(3,4,5)]"

#: assess2/questions/answerboxes/NumberAnswerBox.php:75
#: assess2/questions/answerboxes/NumberAnswerBox.php:71
#: assess2/questions/answerboxes/NumberAnswerBox.php:74
msgid ""
"Enter your answer as a list of integers with units, separated with commas. "
"Example: -4 cm, 3 m"
msgstr ""
"Geben Sie Ihre Antwort als Komma-gtrennte Liste von ganzen Zahlen mit "
"Einheiten ein. Beispiel: -4 cm,3 m"

#: assess2/questions/answerboxes/NumberAnswerBox.php:76
#: assess2/questions/answerboxes/NumberAnswerBox.php:72
#: assess2/questions/answerboxes/NumberAnswerBox.php:75
msgid "Enter a list of integers with units"
msgstr "Geben Sie eine Liste von ganzen Zahlen mit Einheiten ein"

#: assess2/questions/answerboxes/NumberAnswerBox.php:78
#: assess2/questions/answerboxes/NumberAnswerBox.php:74
#: assess2/questions/answerboxes/NumberAnswerBox.php:77
msgid ""
"Enter your answer as a list of integer or decimal numbers with units, "
"separated with commas. Example: -4.2 cm, 3E6 m"
msgstr ""
"Geben Sie Ihre Antwort als Komma-separierte Liste von ganzen Zahlen oder "
"Dezimalzahlen mit Einheiten ein. Beispiel: -4.2 cm, 3E6 m"

