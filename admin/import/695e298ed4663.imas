e(\\\"g\\\",1)\",\"setValue(\\\"j\\\",1)\")\r\n\r\n\/\/this is what we want to get from geogebra on submit.  Gets stored as a comma separated list in the answerbox\r\n$geogebraget = array(\"getValue(\\\"a\\\")\",\"getValue(\\\"b\\\")\")\r\n\r\n\/\/create the geogebra embed.\r\n$g = addGeogebra($geogebracode,800,250,$geogebrainit,array(),$geogebraget,$thisq,0)\r\n\r\n\/\/notice in the question text we use some HTML trickery to put the $answerbox[0] out of view, since it's being autofilled\r\n\r\n\/\/we're grading this as a string, so we want either order since either is OK\r\n$answer[0] = \"$a,$b or $b,$a\"\r\n$showanswer[0] = \"\"\r\n$answer[1] = $a*$b","qcontrol":"","qtext":"Stelle die Schieberegler so ein, dass das Produkt $a * $b angezeigt wird.\r\n\r\n$g\r\n\r\n\u003Cdiv style=\"position:absolute; left:-5000px\"\u003E$answerbox[0]\u003C\/div\u003E\r\nWas ist das Produkt?  $a * $b = $answerbox[1]","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"20":{"uniqueid":1469698652697433,"adddate":1469698652,"lastmoddate":1532866636,"ownerid":2,"author":"dahn,Ingo","userights":2,"description":"m\/(10x+1) : n\/y =k\/(10*l+z)","qtype":"conditional","control":"$anstypes = \"calculated,calculated,calculated\"\r\n$answerformat=\"nodecimal\"\r\n\r\n$x = $stuanswers[$thisq][0]\r\n$y = $stuanswers[$thisq][1]\r\n$z = $stuanswers[$thisq][2]\r\n\r\n$m,$n,$xx,$yy=rands(1,9,4)\r\n$k=$m*$yy\r\n$kk=10*$n*$xx\r\n$kkz=$kk+$n\r\n$kkx=10*$xx+1\r\n\r\n$f=\"$m\/(10 x+1) : $n\/y = $k\/($kk+z)\"\r\n\r\n$answer=($m*$y*($kk+$z)== $k*$n*(10*$x+1)) && (0 \u003C $y) && ($y \u003C 10) && (0 \u003C $x) && ($x \u003C 10) && (0\u003C$z) && ($z\u003C10)","qcontrol":"","qtext":"\u003Cp\u003EFinden Sie Ziffern&nbsp;`x,y,z`&nbsp;so dass&nbsp;`$f`&nbsp;.\u003C\/p\u003E\r\n\u003Cp\u003E`x=`&nbsp;$answerbox[0]\u003C\/p\u003E\r\n\u003Cp\u003E`y=`&nbsp;$answerbox[1]\u003C\/p\u003E\r\n\u003Cp\u003E`z=`&nbsp;$answerbox[2]\u003C\/p\u003E\r\n\u003Cp\u003E&nbsp;\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"\u003Cp\u003E\u003Cstrong\u003E\u003Cspan class=\"ilc_text_inline_Strong\"\u003E1. &Uuml;berlegung:\u003C\/span\u003E \u003C\/strong\u003EMan teilt durch einen Bruch, indem man mit dem Kehrwert multipliziert. Das bedeutet hier:&nbsp;`$m\/(10 x +1) * (y\/$n)= $k\/($kk+z)`&nbsp;.\u003Cbr \/\u003E\u003Cbr \/\u003E\u003Cstrong\u003E\u003Cspan class=\"ilc_text_inline_Strong\"\u003E2. &Uuml;berlegung:\u003C\/span\u003E \u003C\/strong\u003E Schauen wir uns die Rechnung im Z&auml;hler an: `$m * y =$k`&nbsp;.&nbsp;Also muss `y=$yy`&nbsp;sein. Es ergibt sich: &nbsp;&nbsp;`$m\/(10 x + 1) *($yy\/$n)=$k\/($kk+z)`&nbsp;bzw. in der Originalrechnung: `($m\/(10 x +1)):($n\/$yy)=$k\/($kk+z)`&nbsp;.\u003Cbr \/\u003E\u003Cbr \/\u003E\u003Cstrong\u003E\u003Cspan class=\"ilc_text_inline_Strong\"\u003E3. &Uuml;berlegung:\u003C\/span\u003E \u003C\/strong\u003E F&uuml;r den Nenner folgt daraus: `(10 x + 1)*$n = $kk+z`&nbsp;. F&uuml;r `z`&nbsp;berechnet man&nbsp;&nbsp;`1*$n=$n`&nbsp;; f&uuml;r `x`&nbsp;folgt&nbsp; `10*$n*x+ $n= $kkz`&nbsp; Daraus ergibt sich&nbsp;`x = $xx`&nbsp;.\u003C\/p\u003E\r\n\u003Cp\u003E\u003Cbr \/\u003E\u003Cspan class=\"ilc_text_inline_Strong\"\u003E\u003Cstrong\u003EL&ouml;sung:\u003C\/strong\u003E `x=$xx, y=$yy, z= $n`&nbsp;, also&nbsp;&nbsp;`$m\/$kkx : $n\/$yy = $k\/$kkz`&nbsp;\u003C\/span\u003E.&nbsp;\u003C\/p\u003E\r\n\r\n","solutionopts":7,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"21":{"uniqueid":1470647849935518,"adddate":1470647849,"lastmoddate":1581252072,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Drei Bruchzahlen subtrahieren und Terme k\u00c3\u00bcrzen\r\nGetestet: Alexander Auer (local for Ingo dahn von #2471 und #2800)\r\nErg\u00c3\u00a4nzt um Feedback","qtype":"multipart","control":"$anstypes=array(\"calculated\", \"numfunc\")\r\n\r\n$a,$b,$c,$d,$e,$f=rands(1,10,6) where ($b!=$d && $b!=$f && $d!=$f)\r\n\r\n$term[0]=\"$a\/$b-$c\/$d-$e\/$f\"\r\n$answer[0]=makereducedfraction(-$c*$b*$f+$a*$d*$f-$e*$b*$d,$f*$b*$d)\r\n$answerformat[0]=\"reducedfraction\"\r\n$feedbacktext[0]=getfeedbackbasic(\"Richtig, Sie k\u00c3\u00b6nnen mit Br\u00c3\u00bcchen rechnen\",\"Leider falsch. Arbeiten Sie den \u003Ca href=\\\"https:\/\/netmath.vcrp.de\/downloads\/Skripte\/Vorkurs\/HSWildau\/Bruchrechnung\/\\\" target=\\\"_blank\\\"\u003EAbschnitt Bruchrechnung\u003C\/a\u003E durch!\u003Cbr\/\u003EWenn Sie es theoretisch k&ouml;nnen, aber praktisch unsicher sind, nutzen Sie das \u003Ca href=\\\"https:\/\/netmath.vcrp.de\/downloads\/Skripte\/Vorkurs\/HSWildau\/Grundlagen\/_beherrschen_sie_das.html\\\" target=\\\"_blank\\\"\u003ETraining zur Bruchrechnung\u003C\/a\u003E\",$thisq,0)\r\n\r\n$variables[1]=\"a,b,c\"\r\n$term[1]=\"`(25a^2b^3c)\/(35a^3bc)=`\"\r\n$answer[1]=\"`(5b^2)\/(7a)`\"\r\n$requiretimes[1]=\"a,=1,b,=1,c,=0\"\r\n$showanswer[1] = $answer[1]\r\n$feedbacktext[1]=getfeedbackbasic(\"Richtig\",\"Leider falsch. Lassen Sie sich von den Variablen nicht abschrecken. Behandeln Sie sie wie Zahlen, die sie nicht kennen!\",$thisq,1)","qcontrol":"","qtext":"Stellen Sie `$term[0]` als m\u00c3\u00b6glichst weit gek\u00c3\u00bcrzten Bruch dar. Schreiben Sie Ihre Antwort als Bruch (nicht als gemischte Zahl!).\r\n\r\n$answerbox[0]\r\n\r\n$feedbacktext[0]\r\n\r\nK\u00c3\u00bcrzen Sie $term[1] soweit wie m\u00c3\u00b6glich.\r\n\r\n$answerbox[1]\r\n\r\n$feedbacktext[1]","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"Staab,Nikolai","otherattribution":"","a11yalttype":0,"a11yalt":0},"17":{"uniqueid":1472574549526705,"adddate":1472574549,"lastmoddate":1730383108,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Trigonometrische Funktionen, Funktionsgraph","qtype":"multipart","control":"loadlibrary(\"geogebra\")\r\n$anstypes=array(\"number\",\"calculated\")\r\n$answerformat=\"list\"\r\n$answer[0]=\"45,225\"\r\n$answer[1]=\"pi\/4,5*pi\/4\"\r\n\r\n$params['showToolBar'] = 'false'\r\n$params[\"showResetIcon\"] = 'true'\r\n\r\n$id=\"FJtrEDAr\"\r\n\r\n$g=addGeogebra($id,950,560,[],$params)\r\n","qcontrol":"","qtext":"\u003Cp\u003EW&auml;hlen Sie eine der trigonometrischen Funktionen und bewegen Sie den Punkt \u003Cstrong\u003E\u003Cem\u003EP\u003C\/em\u003E\u003C\/strong\u003E. Sie k&ouml;nnen auch den Play-Button links unten benutzen.\u003C\/p\u003E\r\n\u003Cp\u003E$g\u003C\/p\u003E\r\n\u003Cp\u003E\u003Cstrong\u003ETip:\u003C\/strong\u003E Wenn Sie \u003Cem\u003E\u003Cstrong\u003EP\u003C\/strong\u003E\u003C\/em\u003E&nbsp;anclicken, so k&ouml;nnen Sie den Punkt auch mit den Pfeil-Tasten bewegen.&nbsp;\u003C\/p\u003E\r\n\u003Cp\u003EGeben Sie, durch Kommata getrennt, alle Gradzahlen&nbsp;`0 &lt;= alpha &lt;=360`&nbsp;an, f&uuml;r die&nbsp;`sin(alpha) = cos(alpha)`&nbsp;ist: $answerbox[0]\u003C\/p\u003E\r\n\u003Cp\u003EGeben Sie, durch Kommata getrennt, alle Werte `0 &lt;= x&lt;=2pi` &nbsp;an, f&uuml;r die&nbsp;`sin(x) = cos(x)`&nbsp;ist (Schreiben Sie \u003Cem\u003Epi\u003C\/em\u003E f&uuml;r `pi`&nbsp;): $answerbox[1]\u003C\/p\u003E\r\n\u003Cp\u003E&nbsp;\u003C\/p\u003E\r\n\u003Chr \/\u003E\r\n\u003Cp\u003EGeogebra-\u003Ca title=\"Animation\" href=\"https:\/\/www.geogebra.org\/m\/FJtrEDAr\" target=\"_blank\"\u003EAnimation\u003C\/a\u003E von \u003Ca title=\"MichaelLanger\" href=\"https:\/\/www.geogebra.org\/michaellanger\" target=\"_blank\"\u003EMichaelLanger\u003C\/a\u003E&nbsp;(angepasst) Lizenz:&nbsp;\u003Ca href=\"http:\/\/creativecommons.org\/licenses\/by-sa\/3.0\" target=\"_blank\"\u003ECC-BY-SA\u003C\/a\u003E, \u003Ca href=\"http:\/\/www.geogebra.org\/cms\/tos\" target=\"_blank\"\u003EGeoGebra Terms of Use\u003C\/a\u003E\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"5":{"uniqueid":1475152519768263,"adddate":1475152519,"lastmoddate":1679559347,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Lineare Gleichung l\u00c3\u00b6sen - mit Feedback","qtype":"calculated","control":"\/\/ Die Koeffizienten der Gleichung ax+b=c werden zuf\u00c3\u00a4llig gew\u00c3\u00a4hlt...\r\n$a = rand(2,7)\r\n\/\/ ... wobei a und b-c nicht teilerfremd sind, damit es etwas zu k\u00c3\u00bcrze gibt\r\n$b,$c = diffrands(10,50,2) where (gcd($a,$b-$c) != 1)\r\n\r\n$answer = makereducedfraction($c-$b,$a)\r\n\r\n\/\/ Wir w\u00c3\u00a4hlen auch noch die Variable der Gleichung zuf\u00c3\u00a4llig\r\n$v = randfrom(\"a,b,k,x,y,z,t,v,p\")\r\n$answerformat = \"reducedfraction\"\r\n\r\n\/\/ $feedback enth\u00c3\u00a4lt die R\u00c3\u00bcckmeldung an die Studierenden\r\n\/\/ Zun\u00c3\u00a4chst wird kein Feedback angezeigt:\r\n$feedback =\"\"\r\n\r\n\/\/ Wenn der Student etwas eingegeben hat...\r\nif ($stuanswers[$thisq] !== null) {\r\n  \/\/ $term ist die L\u00c3\u00b6sung, die ggf. noch gek\u00c3\u00bcrzt werden muss\r\n  $termv=($c-$b)\/$a;\r\n  \/\/ $stuv ist der numerische Wert der gegebenen Antwort\r\n  $stuv=$stuanswersval[$thisq];\r\n  \/\/ $stua ist der Term, den der Studierende eingegeben hat\r\n  $stua=$stuanswers[$thisq];\r\n  \/\/ Wir konstruieren eine R\u00c3\u00bcckmeldung f\u00c3\u00bcr den Fall, dass die Antwort nicht richtig ist\r\n  \/\/ Vorl\u00c3\u00a4ufiger Kommentar, wird eingesetzt, wenn der Wert der Antwort nicht mit dem Wert der L\u00c3\u00b6sung \u00c3\u00bcbereinstimmt\r\n  $feed=\" $stua ist nicht richtig. Die richtige Antwort ist $answer \";\r\n  \/\/ Wenn der Wert der Antwort doch mit dem Wert der L\u00c3\u00b6sung \u00c3\u00bcbereinstimmt, nehmen wir einen anderen Kommentar\r\n  if (comparenumbers($stuv, $termv)) {\r\n    $feed=\"Der Wert stimmt, aber Sie m\u00c3\u00bcssen noch weiter k\u00c3\u00bcrzen\";\r\n  }\r\n  \/\/ Das erste Argument \"Gut gemacht, $answer ist die L\u00c3\u00b6sung\" wird eingesetzt, falls die Antwort richtig ist, ansonsten wird unser Kommentar ausgegeben:\r\n  $feedback=getfeedbackbasic(\"Gut gemacht, $answer ist die richtige L\u00c3\u00b6sung.\",$feed,$thisq)\r\n}","qcontrol":"","qtext":"L\u00c3\u00b6sen Sie:  `$a $v + $b = $c`. Stellen Sie Ihre L\u00c3\u00b6sung als gek\u00c3\u00bcrzten Bruch dar.\r\n\r\n`$v` = $answerbox\r\n\r\n$feedback","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"Gaa,Julia; dahn,Ingo, mb Dahn,Ingo","otherattribution":"","a11yalttype":0,"a11yalt":0},"16":{"uniqueid":1475320718647560,"adddate":1475320718,"lastmoddate":1697100975,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Mengenoperationen mit Intervallen\r\nAus Wolter, Dahn: Analysis Individuell,\r\n\u00c3\u00a4hnlich #751 aber mit beliebigen Intervallen","qtype":"multipart","control":"$anstypes=array(\"interval\",\"interval\",\"interval\")\r\nloadlibrary(\"interval_ext\")\r\n$xl,$xr,$yl,$yr,$zl,$zr=rands(-4,4,6) where ($xl\u003C$xr && $yl\u003C$yr && $zl\u003C$zr)\r\n$x=randfrom(array(\"[$xl,$xr]\",\"($xl,$xr]\",\"[$xl,$xr)\",\"($xl,$xr)\"))\r\n$y=randfrom(array(\"[$yl,$yr]\",\"($yl,$yr]\",\"[$yl,$yr)\",\"($yl,$yr)\"))\r\n$z=randfrom(array(\"[$zl,$zr]\",\"($zl,$zr]\",\"[$zl,$zr)\",\"($zl,$zr)\"))\r\n\r\n$eqn[0]=\"`X nn Y nn Z`\"\r\n$answer[0]=canonicInterval(intersection(array($x,$y,$z)))\r\n\r\n$eqn[1]=\"`(X uu Y) nn Z`\"\r\n$answer[1]=canonicInterval(intersection(array(\"$x U $y\", $z)))\r\n\r\n$eqn[2]=\"`X uu (Y nn Z)`\"\r\n$yz=intersection(array($y,$z))\r\n$answer[2]=canonicInterval(\"$x U $yz\")\r\n","qcontrol":"","qtext":"\u003Cp\u003ESei `X= $x`, `Y=$y`, `Z=$z`.\r\n  \u003Cbr \/\u003E\u003Cbr \/\u003E\r\n  Geben Sie die folgenden Mengen an:\r\n  \u003Cbr \/\u003E\u003Cbr \/\u003E\r\n  \u003Cem\u003E\u003Cstrong\u003EHinweis:\u003C\/strong\u003E Verwenden Sie U f&uuml;r die Vereinigung von Intervallen, oo f&uuml;r Unendlich und DNE f&uuml;r die leere Menge.\u003C\/em\u003E\r\n  \u003Cbr \/\u003E\u003Cbr \/\u003E\r\n  a) $eqn[0] = $answerbox[0],\r\n  \u003Cbr \/\u003E\u003Cbr \/\u003E\r\n  b) $eqn[1] = $answerbox[1],\r\n  \u003Cbr \/\u003E\u003Cbr \/\u003E\r\n  c) $eqn[2] = $answerbox[2],\u003Cbr \/\u003E.\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"Dahn,Ingo, mb dahn,Ingo","otherattribution":"","a11yalttype":0,"a11yalt":0},"18":{"uniqueid":1475345844137575,"adddate":1475345844,"lastmoddate":1475346406,"ownerid":2,"author":"dahn,Ingo","userights":2,"description":"Berechnung des Widerstands in einer Parallelschaltung","qtype":"number","control":"$r1,$r2,$r3=rrands(100,900,10,3) where ($r1 != $r2)\r\n$answer=1\/(1\/$r1 + 1\/$r2 + 1\/$r3)\r\n$abstolerance=1\r\n","qcontrol":"","qtext":"Der Gesamtwiderstand einer Parallelschaltung (wie bei einer Verteilersteckdose) wird bei drei Verbrauchern nach der Formel `R_{Ges} = 1\/(1\/R_1 + 1\/R_2 + 1\/R_3)` berechnet. \r\n\r\nIn einer solchen Schaltung sind Verbraucher mit den Widerst\u00c3\u00a4nden `R_1 = $r1\\  \\Omega, R_2 = $r2\\ \\Omega, R_3= $r3\\ \\Omega` zusammengeschaltet. Berechne den Gesamtwiderstand auf `1\\ \\Omega` genau.\r\n`R_{Ges} = `$answerbox","answer":"","hasimg":0,"extref":"read!!https:\/\/netmath.vcrp.de\/downloads\/Systeme\/Calculator\/calculator.html!!0","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"22":{"uniqueid":1383365791860916,"adddate":1475480093,"lastmoddate":1476215313,"ownerid":2,"author":"Gray,James, mb dahn,Ingo","userights":2,"description":"Konfidenzintervall","qtype":"multipart","control":"\/\/start randomization code - Tutorial Style question\r\n\r\n\r\n\r\n\/\/end randomization code - Tutorial Style question\r\n\r\n$anstypes = \"choices,choices,choices,choices\"\r\n\r\n$questions[0][0] = \"(3, 4)\"\r\n$feedbacktxt[0][0] = \"Das ist nicht richtig. Das Intervall (3,4) ist nicht das breiteste Intervall. Ein breiteres Intervall liefert eine h\u00c3\u00b6here Sicherheitswahrscheinlichkeit (Konfidenzniveau). Versuche es noch einmal.\"\r\n$questions[0][1] = \"(2.5, 4.5)\"\r\n$feedbacktxt[0][1] = \"Das ist nicht richtig. Das Intervall (2.5, 4.5) ist nicht das breiteste Intervall. Ein breiteres Intervall liefert eine h&ouml;here Sicherheitswahrscheinlichkeit (Konfidenzniveau).&nbsp;Versuche es noch einmal.\"\r\n$questions[0][2] = \"(2, 5)\"\r\n$feedbacktxt[0][2] = \"Sehr gut! Das breiteste Intervall liefert uns die h&ouml;chste Sicherheitswahrscheinlichkeit (Konfidenzniveau).\"\r\n$displayformat[0] = \"vert\"\r\n$noshuffle[0] = \"all\"\r\n$answer[0] = 2\r\n\r\n$questions[1][0] = \"das 90% Konfidenzintervall\"\r\n$feedbacktxt[1][0] = \"Das ist nicht richtig. Die % Angabe gibt die Wahrscheinlichkeit an, mit welcher das Intervall den unbekannten Erwartungswert (\u003Cspan class=\\\"AM\\\" title=\\\"mu\\\"\u003E`mu`\u003C\/span\u003E&nbsp;) der Population enth&auml;lt. Versuche es noch einmal.\"\r\n$questions[1][1] = \"das 95% Konfidenzintervall\"\r\n$feedbacktxt[1][1] = \"Das ist nicht richtig.&nbsp;Die % Angabe gibt die Wahrscheinlichkeit an, mit welcher das Intervall den unbekannten Erwartungswert (\u003Cspan class=\\\"AM\\\" title=\\\"mu\\\"\u003E`mu`\u003C\/span\u003E&nbsp;) der Population enth&auml;lt. Versuche es noch einmal.\"\r\n$questions[1][2] = \"das 99% Konfidenzintervall\"\r\n$feedbacktxt[1][2] = \"Prima, das ist richtig! Die % Angabe gibt die Wahrscheinlichkeit an, mit welcher das Intervall den unbekannten Erwartungswert (\u003Cspan class=\\\"AM\\\" title=\\\"mu\\\"\u003E`mu`\u003C\/span\u003E&nbsp;) der Population enth&auml;lt.\u003Cbr \/\u003EDamit ist das \u003Cstrong\u003Ebreiteste\u003C\/strong\u003E Intervall dasjenige mit dem \u003Cstrong\u003Egr&ouml;&szlig;ten Konfidenzniveau\u003C\/strong\u003E.\"\r\n$displayformat[1] = \"select\"\r\n$noshuffle[1] = \"all\"\r\n$answer[1] = 2\r\n\r\n$questions[2][0] = \"(3, 4)\"\r\n$feedbacktxt[2][0] = \"Prima, das ist richtig!&nbsp;Das kleinste Intervall liefert die genaueste Sch&auml;tzung f&uuml;r den unbekannten Erwartungswert.\"\r\n$questions[2][1] = \"(2, 5)\"\r\n$feedbacktxt[2][1] = \"Das ist nicht richtg. Je kleiner das Intervall, desto genauer die Sch&auml;tzung&nbsp;des unbekannten Erwartungswertes. Versuche es noch einmal.\"\r\n$questions[2][2] = \"(2.5, 4.5)\"\r\n$feedbacktxt[2][2] = \"Das ist nicht richtg. Je kleiner das Intervall, desto genauer die Sch&auml;tzung&nbsp;des unbekannten Erwartungswertes. Versuche es noch einmal.\"\r\n$displayformat[2] = \"select\"\r\n$noshuffle[2] = \"all\"\r\n$answer[2] = 0\r\n\r\n$questions[3][0] = \"das 99% Konfidenzintervall\"\r\n$feedbacktxt[3][0] = \"Das ist nicht richtig!. Beachte den Zusammenhang zwischen Genauigkeit und Sicherheitswahrscheinlichkeit eines Konfidenzintervalls. Versuche es noch einmal.\"\r\n$questions[3][1] = \"das 95% Konfidenzintervall\"\r\n$feedbacktxt[3][1] = \"Das ist nicht richtig!. Beachte den Zusammenhang zwischen Genauigkeit und Sicherheitswahrscheinlichkeit eines Konfidenzintervalls. Versuche es noch einmal.\"\r\n$questions[3][2] = \"das 90% Konfidenzintervall\"\r\n$feedbacktxt[3][2] = \"Prima. Das ist richtig! \u003Cbr \/\u003EDas Intervall, welches die genaueste Sch&auml;tzung liefert, ist das kleinste Intervall und hat folglich die geringste Sicherheitswahrscheinlichkeit.\"\r\n$displayformat[3] = \"select\"\r\n$noshuffle[3] = \"all\"\r\n$answer[3] = 2\r\n\r\n\r\n\/\/end stored values - Tutorial Style question\r\n\r\n\r\n\r\n\/\/end retained code - Tutorial Style question\r\n\r\n\r\n$feedback[0] = getfeedbacktxt($stuanswers[$thisq][0], $feedbacktxt[0], $answer[0])\r\n$feedback[1] = getfeedbacktxt($stuanswers[$thisq][1], $feedbacktxt[1], $answer[1])\r\n$feedback[2] = getfeedbacktxt($stuanswers[$thisq][2], $feedbacktxt[2], $answer[2])\r\n$feedback[3] = getfeedbacktxt($stuanswers[$thisq][3], $feedbacktxt[3], $answer[3])\r\n","qcontrol":"","qtext":"\u003Ch3\u003E\u003Cspan style=\"color: #3366ff;\"\u003EHabe ich das verstanden?\u003C\/span\u003E\u003C\/h3\u003E\r\n\u003Cp\u003EIn einer Studie wurden 1.115 zuf&auml;llig ausgew&auml;hlte M&auml;nner zwischen 25 und 35 Jahren nach dem Zeitaufwand f&uuml;r &Uuml;bungen gefragt.\u003C\/p\u003E\r\n\u003Cp\u003EBasierend auf dieser Studie wurde der erwartete Zeitaufwand durch den Mittelwert des Zeitaufwandes der 1115 M&auml;nner gesch&auml;tzt,&nbsp;sowie die 90%, 95%, und 99% Konfidenzintervalle des erwarteten Zeitaufwandes berechnet.&nbsp;Diese Intervalle sind (nicht unbedingt in der gleichen Reihenfolge):\u003C\/p\u003E\r\n\u003Cp\u003E&nbsp;\u003Cimg id=\"_i_1\" class=\" popimg\" title=\"Three number lines illustrating three confidence intervals. The first is shows an interval of (3,4). The second, an interval of (2.5, 4.5), and the third, (2,5).\" src=\"https:\/\/s3-us-west-2.amazonaws.com\/oliimgs\/_u5_m1_dig3a.gif\" alt=\"Drei Zahlengeraden die drei Konfidenzintervalle illustrieren.  Das erste zeigt das Interval (3,4)., das zweite das Intervall (2.5, 4.5) und das dritte (2,5).\" width=\"338\" height=\"144\" \/\u003E\u003C\/p\u003E\r\n\u003Cdiv class=\"image shouldbeleft\"\u003E&nbsp;\u003C\/div\u003E\r\n\u003Cdiv class=\"image shouldbeleft\"\u003EWelches der drei Intervalle hat das h&ouml;chste \u003Cstrong\u003EKonfidenzniveau&nbsp;\u003C\/strong\u003Ed.h Sicherheitswahrscheinlichkeit daf&uuml;r, den wahren erwarteten Zeitaufwand `mu`&nbsp;zu enthalten: $answerbox[0] $feedback[0]\u003C\/div\u003E\r\n\u003Cdiv class=\"image shouldbeleft\"\u003E&nbsp;\u003C\/div\u003E\r\n\u003Cdiv class=\"image shouldbeleft\"\u003EDas Konfidenzintervall f&uuml;r den Erwartungswert `mu`&nbsp;des Zeitaufwandes der Population mit der h&ouml;chsten Sicherheitswahrscheinlichkeit ist $answerbox[1]. $feedback[1]\u003C\/div\u003E\r\n\u003Cdiv class=\"image shouldbeleft\"\u003E\u003Cbr \/\u003EDie genaueste Sch&auml;tzung liefert das Konfidenzintervall $answerbox[2]. $feedback[2]\u003C\/div\u003E\r\n\u003Cdiv class=\"image shouldbeleft\"\u003E&nbsp;\u003C\/div\u003E\r\n\u003Cdiv class=\"image shouldbeleft\"\u003EDas Konfidenzintervall, welches die genaueste Sch&auml;tzung liefert, ist $answerbox[3]. $feedback[3]\u003C\/div\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"14":{"uniqueid":1529581680106129,"adddate":1529581680,"lastmoddate":1529581680,"ownerid":12208,"author":"Steinel,Leandro","userights":0,"description":"Beliebiges lineares Gleichungssystem mit zwei Unbekannten (local for Leandro Steinel)","qtype":"calculated","control":"$a=nonzerorands(-9,9,4)\r\n\r\n\/\/ $a=[2,2,2,2]\r\n$c=nonzerorands(-5,5,2)\r\n\/\/ $c=[1,1]\r\n$det=$a[0]*$a[3]-$a[1]*$a[2]\r\n$answerformat=\"exactlist,nosolninf\"\r\n$ansprompt=\"x,y=;Es gibt keine L\u00c3\u00b6sung;Es gibt unendlich viele L\u00c3\u00b6sungen\"\r\n\r\nif ($det != 0) {\r\n  $answer=\"($a[3]*$c[0]-$a[1]*$c[1])\/$det,($a[0]*$c[1]-$a[2]*$c[0])\/$det\"\r\n} else {\r\n  if($a[0]*$c[1]==$a[2]*$c[0]) {\r\n    $answer=\"infinite\";\r\n  } else {\r\n    $answer=\"DNE\";\r\n  }\r\n}\r\n\r\n$p1=makexxpretty(\"$a[0]*x+$a[1]*y\")\r\n$p2=makexxpretty(\"$a[2]*x+$a[3]*y\")\r\n","qcontrol":"","qtext":"L\u00c3\u00b6sen Sie das folgende lineare Gleichungssystem:\u003C\/p\u003E\r\n`{($p1,=,$c[0]),($p2,=,$c[1]):}`\u003C\/p\u003E\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"dahn,Ingo; Behzadi,Mojdeh; Gaa,Julia","otherattribution":"","a11yalttype":0,"a11yalt":0},"24":{"uniqueid":1529646213483404,"adddate":1529646213,"lastmoddate":1529646213,"ownerid":12208,"author":"Steinel,Leandro","userights":0,"description":"Extremwert und Ableitung 1\r\nCosh06a-1.3.1 (local for Leandro Steinel)","qtype":"conditional","control":"$anstypes = array(\"choices\",\"number\",\"number\",\"number\",\"number\",\"number\")\r\n$questions[0] = array(\"Das ist immer richtig\",\"Das ist nicht immer richtig\");\r\n$noshuffle[0] = \"all\"\r\n$feedback=\"Versuche die Frage\"\r\n$answer=0;\r\n$answerboxsize = 2 \r\n\/\/ if something has been selected...\r\nif ($stuanswers != null && $stuanswers[$thisq] != null) {\r\n  \r\n  $ans=[]\r\n  \/\/ Get the selection\r\n  $choice1 = getstuans($stuanswers,$thisq,0)\r\n  for ($i=0..5) {\r\n    $ans[$i]=getstuans($stuanswers,$thisq,$i)\r\n  }\r\n  $choice1=$ans[0]\r\n  $fb0=\"Bitte etwas ausw\u00c3\u00a4hlen.\"\r\n  $fb1=\"Das ist falsch.\"\r\n  if($choice1 === null) {\r\n      \/\/ This will be true if user has not selected anything as this is a multiple choice item\r\n  } elseif ($choice1 == 0) {\r\n      \/\/ This is always true\r\n    \t$fb0=\"Das stimmt nicht.\"\r\n  } else {\r\n      \/\/ This is not always true\r\n      $answer=0.3;\r\n    if ($ans[1] == null || $ans[2]== null || $ans[3]== null || $ans[4]== null || $ans[5] == null) {\r\n      $fb1=\"Bitte geben Sie ein vollst\u00c3\u00a4ndiges Gegenbeispiel an.\"\r\n    } else {\r\n      if ($ans[1]==0) {\r\n        $fb1=\"Das ist kein Polynom 3. Grades!\"\r\n      } else {\r\n        \/\/ $f=\"$ans[1]*x^3+$ans[2]*x^2+$ans[3]*x+$ans[4]\"\r\n      $f1=\"3*$ans[1]*x^2+2*$ans[2]*x+$ans[3]\"\r\n      $x0=$ans[5]\r\n      $val=evalfunc($f1,\"x\",$x0)\r\n      if ($val == 0) {\r\n        $fb1=\"Die Ableitung hat eine Nullstelle bei `x_0`.\"\r\n        $f2=\"6*$ans[1]*x+3*$ans[2]\"\r\n        $val=evalfunc($f2,\"x\",$x0)\r\n        if ($val == 0) {\r\n          $answer=1\r\n          $fb1=\"Das Gegenbeispiel ist richtig! Die Ableitung hat eine Nullstelle bei `x_0`, aber `x_0` ist keine Extremstelle von `f`.\"\r\n        } else {\r\n          $fb1=\"Das ist kein Gegenbeispiel - Die Ableitung ist zwar 0 bei `x_0`, aber `x_0` ist auch eine Extremstelle von `f`.\"\r\n        }\r\n      } else {\r\n        $fb1=\"Das ist kein Gegenbeispiel - Die Ableitung ist nicht 0 bei `x_0`!\"\r\n      }\r\n      }\r\n      \r\n    }\r\n  }\r\n}\r\n\r\n$feedback=getfeedbacktxt($choice1,[$fb0,$fb1],1)","qcontrol":"","qtext":"Sei `f` ein Polynom 3. Grades. Ist die folgende Aussage richtig? Wenn Sie meinen dass sie nicht richtig ist, so geben Sie ein Gegenbeispiel daf\u00c3\u00bcr an.\r\n\r\nWenn `f'(x_0) = 0` ist, dann ist `x_0` eine Extremstelle von` f`.\r\n\r\n$answerbox[0]\r\n\r\n\u003Cscript type=\"text\/javascript\"\u003E\r\n  $(function() {\r\n    $(\"input[name=qn{$thisq}000]\").on('change', function(e) {\r\n      var val = e.target.value;\r\n      $(\"div[id^=mcshowhide$thisq]\").each(function(i,t) {\r\n        t.style.display = (t.id==\"mcshowhide$thisq-\"+val)?\"\":\"none\";\r\n      });\r\n    }).each(function(i,t) {\r\n      if (t.checked) { $(\"#mcshowhide$thisq-\"+t.value).show();}\r\n    });\r\n  });\r\n\u003C\/script\u003E\r\n\u003Cdiv id=\"mcshowhide$thisq-0\" style=\"display:none;\"\u003E\u003C\/div\u003E\r\n\u003Cdiv id=\"mcshowhide$thisq-1\" style=\"display:none;\"\u003E\r\n  Geben Sie ein Gegenbeispiel an:\r\n  \u003Cbr \/\u003E\r\n  `f(x)=` $answerbox[1] `x^3` + $answerbox[2] `x^2` + $answerbox[3] `x` + $answerbox[4] \r\n  \u003Cbr \/\u003E\r\n  `x_0` = $answerbox[5]\r\n\u003C\/div\u003E\r\n\r\n$feedback","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"dahn,Ingo","otherattribution":"","a11yalttype":0,"a11yalt":0},"27":{"uniqueid":1561194017142294,"adddate":1561194017,"lastmoddate":1719085097,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Doppelbruch mit Variablen vereinfachen mit SageCell","qtype":"numfunc","control":"loadlibrary(\"sagecell_vcrp\")\r\n$k,$e,$b,$l,$d,$g=rands(1,9,6)\r\n$h=$k*$b\r\n$c=$k*$e\r\n$f=$l*$d\r\n$a=$g*$l\r\n$variables='x,y'\r\n$z=\"($a x)\/($b y)+ $c\/$d\"\r\n$zz=\"($a*x)\/($b*y)+ $c\/$d\"\r\n$n=\"($e y)\/($f x)+ $g\/$h\"\r\n$nn=\"($e*y)\/($f*x)+ $g\/$h\"\r\n$t=\"($z)\/($n)\"\r\n$tt=makexxpretty($t)\r\n$u=$h*$f\/($b*$d)\r\n$answer=\"$u x\/y\"\r\n$script=\"var('x,y')\r\nt=($zz)\/($nn)\r\nt\"\r\n$cell=sagecell($script,$thisq)\r\n$button=sagecellButton(\"Ergebnis \u00c3\u00bcbernehmen\")\r\n$requiretimes=\"\/,\u003C2\"\r\n$formatfeedbackon=true","qcontrol":"","qtext":"Vereinfachen Sie `$tt`. \u00c3\u0153berlegen Sie, welche Befehle Terme vereinfachen.\r\n\r\n\u003Cb\u003EBerechnung:\u003C\/b\u003E\r\n$cell\r\n$button\r\n\r\n$answerbox\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"28":{"uniqueid":1561395954003392,"adddate":1561395954,"lastmoddate":1582388595,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Br\u00c3\u00bcche anwenden mit SageCell","qtype":"multipart","control":"loadlibrary(\"sagecell_vcrp\")\r\n$anstypes=\"calculated,calculated,calculated\"\r\n$b,$d,$f=diffrandsfrom(\"2,3,4,5,8,10\",3)\r\n$a,$c=rands(6,9,2) \r\n\r\n\r\n$term=\"$a\/$b+$c\/$d-$e\/$f\"\r\n$z1=$a*$d+$c*$b\r\n$n1=$b*$d\r\n\r\n$e=rand(2,min(11,$f*$z1\/$n1))\r\n$script=\"v1=$a*(1\/$b)\r\nv2=$c*(1\/$d)\r\nv3=$e*(1\/$f)\r\n\"\r\n$cell=sagecell($script,$thisq)\r\n$button1=sagecellButton(\"Ergebnis als Restvolumen des Gemischs \u00c3\u00bcbernehmen\",0)\r\n$button2=sagecellButton(\"Ergebnis als Restvolumen von Fl\u00c3\u00bcssigkeit 1 \u00c3\u00bcbernehmen\",1)\r\n$button3=sagecellButton(\"Ergebnis als Restvolumen von Fl\u00c3\u00bcssigkeit 2 \u00c3\u00bcbernehmen\",2)\r\n\r\n$z2=$z1*$f-$e$n1\r\n$n2=$n1*$f\r\n$answer[0]=makereducedfraction($z2,$n2)\r\n\r\n$answer[1]=makereducedfraction($a*$z2*$n1,$b*$n2*$z1)\r\n\r\n$answer[2]=makereducedfraction($c*$z2*$n1,$d*$n2*$z1)\r\n\r\n$answerformat=\"reducedfraction\"\r\n$formatfeedbackon=true\r\n$hidepreview=true","qcontrol":"","qtext":"Es werden $a mal `1\/$b` l einer Fl\u00c3\u00bcssigkeit mit $c mal `1\/$d` l einer anderen Fl\u00c3\u00bcssigkeit gemischt. Dem Gemisch werden $e mal `1\/$f` l entnommen. Geben Sie die Antworten auf die folgenden Fragen als gek\u00c3\u00bcrzte Br\u00c3\u00bcche ein.\r\n\r\na) Wie gro\u00c3\u0178 ist das verbleibende Volumen des Gemischs?\r\n\r\n$answerbox[0] l\r\n\r\nb) Wieviel Liter von Fl\u00c3\u00bcssigkeit 1 sind im Rest des Gemischs enthalten?\r\n\r\n$answerbox[1] l\r\n\r\nc) Wieviel Liter von Fl\u00c3\u00bcssigkeit 2 sind im Rest des Gemischs enthalten?\r\n\r\n$answerbox[2] l\r\n\r\n\u003Cb\u003EBerechnung:\u003C\/b\u003E\r\n\r\n$cell\r\n$button1 $button2 $button3\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"45":{"uniqueid":1580112572310228,"adddate":1580112572,"lastmoddate":1586201813,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Prognose Coronavirus (nach WHO-Daten), Exponentialfunktion","qtype":"multipart","control":"loadlibrary(\"stats\")\r\n$anstypes=array(\"draw\",\"choices\",\"number\",\"number\",\"number\")\r\n\r\n\r\n$maxInfects=60000\r\n# $dates=array(\"2020-01-21\",\"2020-01-22\",\"2020-01-23\",\"2020-01-24\",\"2020-01-25\",\"2020-01-26\")\r\n$dates=array(\"21.1.2020\",\"22.1.2020\",\"23.1.2020\",\"24.1.2020\",\"25.1.2020\",\"26.1.2020\",\"27.1.2020\",\"28.1.2020\",\"29.1.2020\",\"30.1.2020\",\"31.1.2020\",\"1.2.2020\",\"2.2.2020\",\"3.2.2020\",\"4.2.2020\",\"5.2.2020\",\"6.2.2020\",\"7.2.2020\",\"8.2.2020\",\"9.2.2020\",\"10.2.2020\",\"11.2.2020\",\"12.2.2020\",\"13.2.2020\",\"14.2.2020\",\"15.2.2020\",\"16.2.2020\")\r\n$infects=array(278,309,573,834,1294,1982,2757,4530,5989,7728,9711,11811,14401,17228,20461,24352,28049,31195,34582,37234,40217,42690,44712,46532,48530,50036,51174)\r\n$nData=count($infects)-1\r\n\r\n$endDateNr=10\r\n$endDateNr1=$endDateNr-1\r\n$endDateNr2=$endDateNr+2\r\n\r\n$date1=$dates[$endDateNr]\r\n$date2=$dates[$endDateNr+1]\r\n$date3=$dates[$endDateNr+2]\r\n\r\n$quotients=[]\r\nfor ($i=2..$endDateNr) {\r\n  $quotients[$i-2]=$infects[$i-1]\/$infects[$i-2]\r\n}\r\n$q=mean($quotients)\r\n$factors=[];\r\nfor ($i=1..$endDateNr) {\r\n  $factors[$i-1]=$infects[$i-1]\/($q^($i-1))\r\n}\r\n$f=mean($factors)\r\n$data=showarrays(\"Datum\",$dates,\"Infektionen\",$infects)\r\n$answer[0]=\"$f*$q^x\"\r\n$points=[\"x=$endDateNr,red\"]\r\nfor ($i=1..$endDateNr) {\r\n  $points[$i]=\"dot,\".($i-1).\",\".$infects[$i-1]\r\n}\r\n$p=showplot($points,0,$endDateNr2,0,10000,\"1:500\")\r\n$background[0]=$points\r\n$answerformat[0]=\"twopoint,line,parab,horizparab,cubic,sqrt,cuberoot,exp,log\"\r\n$grid[0]=\"0:-2,$endDateNr+2,0:-500,15000,1:1:Tage,1000:1000:Infektionen,300,600\"\r\n\r\n$questions[1]=array(\"linear\",\"quadratisch\",\"kubisch\",\"logarithmisch\",\"exponentiell\")\r\n$answer[1]=4\r\n$displayformat=\"select\"\r\n\r\n$answer[2]=$infects[$endDateNr]\r\n$reltolerance[2]=0.1\r\n$answer[3]=$infects[$endDateNr+1]\r\n$reltolerance[3]=0.1\r\n$answer[4]=$infects[$endDateNr+2]\r\n$reltolerance[4]=0.1\r\n\r\n$fb2=\"\"\r\nif (getstuans($stuanswers,$thisq,2) !== null) {\r\n  $tol=abs(1-$answer[2]\/getstuans($stuanswers,$thisq,2))\r\n  $tol=abs(round((1-$answer[2]\/getstuans($stuanswers,$thisq,2))*100,0))\r\n  $fb2=\"Ihre Sch\u00c3\u00a4tzung weicht um $tol % von der realen Zahl der Infektionen am $date1 ab.\"\r\n}\r\n\r\n$fb3=\"\"\r\nif (getstuans($stuanswers,$thisq,3) !== null) {\r\n  $tol=abs(1-$answer[3]\/getstuans($stuanswers,$thisq,3))\r\n  $tol=abs(round((1-$answer[3]\/getstuans($stuanswers,$thisq,3))*100,0))\r\n  $fb3=\"Ihre Sch\u00c3\u00a4tzung weicht um $tol % von der realen Zahl der Infektionen am $date2 ab.\"\r\n}\r\n\r\n$fb4=\"\"\r\nif (getstuans($stuanswers,$thisq,4) !== null) {\r\n  $tol=abs(1-$answer[4]\/getstuans($stuanswers,$thisq,4))\r\n  $tol=abs(round((1-$answer[4]\/getstuans($stuanswers,$thisq,4))*100,0))\r\n  $fb4=\"Ihre Sch\u00c3\u00a4tzung weicht um $tol % von der realen Zahl der Infektionen am $date3 ab.\"\r\n}\r\n","qcontrol":"","qtext":"Das folgende Diagramm zeigt die Anzahl der im Labor best\u00c3\u00a4tigten Infektionen mit dem Coronavirus in China; Tag 0 ist der 21.1.2020, der Tag des Beginns der \u003Ca href=\"https:\/\/www.who.int\/emergencies\/diseases\/novel-coronavirus-2019\/situation-reports\" target=\"_blank\"\u003Et\u00c3\u00a4glichen Reports der WHO\u003C\/a\u003E:\r\n\r\nZeichnen Sie eine Kurve, die die Zahl der Infektionen bis zum 31.1.2010 (Tag 10) m\u00c3\u00b6glichst gut ann\u00c3\u00a4hert:\r\n\r\n$answerbox[0]\r\n\r\nDas Wachstum der Zahl der Infektionen im Januar ist $answerbox[1]\r\n\r\nSch\u00c3\u00a4tzen Sie die Zahl der Infektionen \r\n\r\nam $date1 (Tag $endDateNr): $answerbox[2] $fb2\r\n\r\nam $date2: $answerbox[3] $fb2\r\n\r\nam $date3: $answerbox[4] $fb4\r\n\r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"26":{"uniqueid":1581256797251969,"adddate":1581256797,"lastmoddate":1582278738,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Prognose Coronavirus nach WHO-Daten, logistische Funktion. (Geogebra-Version)","qtype":"conditional","control":"includecodefrom(EID45)\r\n$infectList=arraytolist($infects)\r\nloadlibrary(\"geogebra\")\r\n\r\n$anstypes=array(\"number\")\r\n\r\n$answer=0;\r\n$backgroundColor=\"Crimson\"\r\n$color=\"White\"\r\n$S=30000\r\n$k=10^(-6)\r\n$fb=\"Zeichnen Sie so eine Kurve, die die Zahl der Infektionen m\u00c3\u00b6glichst gut ann\u00c3\u00a4hert.\"\r\n$maxDiffDay=0\r\nif (getstuans($stuanswers,$thisq,0)!== null) {\r\n  $stuansarray=explode(\",\",getstuans($stuanswers,$thisq,0))\r\n  $S=$stuansarray[0]\r\n  $k=$stuansarray[1]\r\n  $answer=1\r\n  $a=278\r\n  $f=\"$a*$S\/($a+($S-$a)*e^(-$k*$S*x))\"\r\n  for ($i=3..$nData) {\r\n    $v=$infects[$i]\r\n    $vf=1-abs($v-evalfunc($f,\"x\",$i))\/$v\r\n    if ($fv\u003C$answer) {\r\n      $maxDiffDay=$i\r\n      $answer=$vf\r\n    }\r\n  }\r\n  $fbpercent=round((1-$answer)*100,0)\r\n  if ($answer \u003E= 0.7) {\r\n    $backgroundColor=\"CornFlowerBlue\"\r\n    $color=\"White\"\r\n  }\r\n  if ($answer \u003E= 0.9) {\r\n    $backgroundColor=\"LightGreen\"\r\n    $color=\"Black\"\r\n  }\r\n  $fb=\"Sie sch\u00c3\u00a4tzen f\u00c3\u00bcr die maximale Anzahl der Infektionen `S=`$S und f\u00c3\u00bcr den Faktor `k=`$k. Ihre Kurve weicht um h\u00c3\u00b6chstens $fbpercent % von den realen Werten ab (Tag $maxDiffDay).\"\r\n}\r\n\r\n$geogebrainit=array(\"setValue('S',$S)\",\"setValue('k',$k)\")\r\nfor ($i=0..$nData) {\r\n  $geogebrainit[2*$i+2]=\"setListValue('listx',$i,$i)\"\r\n  $geogebrainit[2*$i+3]=\"setListValue('listy',$i,$infects[$i])\"\r\n}\r\n\r\n$geogebraget = array(\"getValue(\\\"S\\\")\",\"getValue(\\\"k\\\")\")\r\n\r\n#$geo=addGeogebra(\"ghtbwcpj\",1000,700,[],[],$geogebraget,$thisq,0)\r\n$geo=addGeogebra(\"hx4rmh53\",1200,620,$geogebrainit,[],$geogebraget,$thisq,0)\r\n","qcontrol":"","qtext":"Das folgende Diagramm zeigt die Anzahl der im Labor best\u00c3\u00a4tigten Infektionen mit dem Coronavirus in China nach WHO-Daten; Tag 0 ist der 21.1.2020 (der Beginn der \u003Ca href=\"https:\/\/www.who.int\/emergencies\/diseases\/novel-coronavirus-2019\/situation-reports\" target=\"_blank\"\u003Et\u00c3\u00a4glichen Reports der WHO\u003C\/a\u003E):\r\n\r\n$geo\r\n\r\nDurch Ziehen der Regler setzen Sie die Parameter `S` und `k` f\u00c3\u00bcr die logistische Funktion `a*S\/(a+(S-a)*e^(-kS*x))`, die dann graphisch dargestellt wird; `a=278` ist der Wert am Tag 0.\r\n\u003Cdiv style=\"position: absolute; left: -5000px;\"\u003E$answerbox[0]\u003C\/div\u003E\r\n\r\n\u003Cdiv style=\"background-color:$backgroundColor; color: $color; padding: 1em;\"\u003E$fb\u003C\/div\u003E\r\n","answer":"","hasimg":0,"extref":"video!!https:\/\/youtu.be\/okTwq17PZjM!!0~~video!!https:\/\/youtu.be\/Jojf2hPnEqA!!0~~video!!https:\/\/youtu.be\/1eIdEvHuaus!!0","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0,"dependencies":{"0":45}},"29":{"uniqueid":1595589505626708,"adddate":1595589505,"lastmoddate":1595589568,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Bereich durch Ungleichungen beschreiben","qtype":"numfunc","control":"$variables=\"x,y\"\r\n$answerformat=\"inequality\"\r\n$p1,$q1,$p2,$q2=diffrands(-5,5,4)\r\n$cx=$q2-$q1; $cy=$p1-$p2; $c=$p1*$q2-$p2*$q1\r\n$li=polymakepretty(\"$cx x + $cy y\")\r\nif ($cy \u003E 0) {\r\n  $answer=\"$li \u003C $c\"\r\n} else {\r\n  $answer=\"$li \u003E $c\"\r\n}","qcontrol":"","qtext":"Geben Sie eine Ungleichung an, die den Bereich unterhalb der Geraden durch die Punkte `($p1,$q1), ($p2,$q2)` (ohne die Gerade selbst) beschreibt.\r\n\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"30":{"uniqueid":1595836089834763,"adddate":1595836089,"lastmoddate":1595836725,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Quadratische Gleichung in 3 Schritten l\u00c3\u00b6sen","qtype":"multipart","control":"$anstypes=array(\"calculated\", \"choices\",\"calculated\")\r\n$reqdecimals[2]=4\r\n$p,$q=nonzerorands(-9,9,2)\r\n$eq=polymakepretty(\"x^2+$p x + $q\")\r\n$D=($p\/2)^2-$q\r\n$answer[0]=$D\r\n$questions[1]=array(\"keine\",\"genau eine\",\"genau zwei\",\"mehr als zwei\")\r\n$answer[1]=0 if ($D \u003C 0)\r\n$answer[1]=1 if ($D == 0)\r\n$answer[1]=2 if ($D \u003E 0)\r\n$answerformat[2]=\"list\"\r\nif ($D \u003E=0) {\r\n  $x1 = -($p\/2)-sqrt($D)\r\n  $x2 = -($p\/2)+sqrt($D)\r\n  $answer[2]=\"$x1,$x2\"\r\n} else {\r\n  $answer[2]=\"\"\r\n}","qcontrol":"","qtext":"L\u00c3\u00b6sen Sie `$eq = 0`.\r\n\r\n1. Bestimmen Sie die Diskriminante `D=`$answerbox[0]\r\n\r\n\/\/\/\/\r\n\r\n2. Wie viele relle L\u00c3\u00b6sungen hat die Gleichung? $answerbox[1]\r\n\r\n\/\/\/\/\r\n\r\n3. Geben Sie alle L\u00c3\u00b6sungen an (durch Komma getrennt)\r\n$answerbox[2]","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"31":{"uniqueid":1613398738994915,"adddate":1613398738,"lastmoddate":1613399442,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Frage mit physikalischen Einheiten","qtype":"number","control":"$v1,$v2=rands(10,20,2)\r\n$v1v=$v1*100\r\n$v2v=$v2*100\r\n$v2s=round($v2v*0.27777778,0) \/\/ cm^3\/s\r\n\r\n$answerformat=\"units\"\r\n$v=$v1v+$v2v\r\n$answer=\"$v l\/h\"","qcontrol":"","qtext":"Ein Becken wird von zwei Pumpen mit Wasser bef\u00c3\u00bcllt. Die erste f\u00c3\u00b6rdert $v1v l\/h, die zweite $v2s cm\u003Csup\u003E3\u003C\/sup\u003E\/s. Wieviel f\u00c3\u00b6rdern beide zusammen (die Einheit k\u00c3\u00b6nnen Sie frei w\u00c3\u00a4hlen)?\r\n\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"32":{"uniqueid":1637353300416043,"adddate":1637353300,"lastmoddate":1758717460,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Skizzieren der Ableitung einer Funktion","qtype":"draw","control":"$deg=randfrom(\"2,3,4\")\r\n\r\n$c1,$c2,$c3,$c4=nonzerorands(-2,2,4)\r\n$c0=0.5\r\n\r\nif ($deg == 4) {\r\n  $f=\"-1\/12*(12*$c1*$c2*$c3*x + 4*($c1 + $c2 + $c3)*x^3 - 3*x^4 - 6*($c1*$c2 + ($c1 + $c2)*$c3)*x^2)*$c0\"\r\n  $answer=\"$c0*(x-$c1)*(x-$c2)*(x-$c3)\"\r\n}\r\nif ($deg == 3) {\r\n  $f=\"1\/6*(6*$c1*$c2*x - 3*($c1 + $c2)*x^2 + 2*x^3)*$c0\"\r\n  $answer=\"$c0*(x-$c2)*(x-$c1)\"\r\n}\r\nif ($deg == 2) {\r\n  $f=\"-1\/2*(2*$c1*x - x^2)*$c0\"\r\n  $answer=\"$c0*(x-$c1)\"\r\n}\r\n$answerformat=\"freehand\"\r\n$background=$f\r\n$reltolerance=2\r\n\r\n\r\n","qcontrol":"","qtext":"Skizzieren Sie die Ableitung dieser Funktion.\r\n\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"\u003Ch3\u003EAufgabe:\u003C\/h3\u003E\r\n\u003Cp\u003EErmitteln Sie grafisch die Ableitung dieser Funktion!\u003Cbr \/\u003EBei dieser Aufgabe ist es nicht das Ziel, konkrete Zahlenwerte f\u00c3\u00bcr die Steigung zu ermitteln; es soll lediglich die Gr\u00c3\u00b6\u00c3\u0178enordnung der Steigung an einer bestimmten Stelle im Vergleich zu anderen eingesch\u00c3\u00a4tzt werden, um ein Gef\u00c3\u00bchl f\u00c3\u00bcr das Konzept \"Ableitung\" zu bekommen.\u003C\/p\u003E\r\n\u003Cp\u003E\u003Cimg style=\"border: 0;\" alt=\"ein Graph im Koordinatensystem\" src=\"https:\/\/netmath.vcrp.de\/downloads\/Skripte\/Vorkurs\/HSWildau21\/img\/Ableitungen1.jpg\" width=\"555\" height=\"555\" border=\"0\" \/\u003E\u003C\/p\u003E\r\n\u003Cp\u003E\u00c2\u00a0\u003C\/p\u003E\r\n\u003Ch3\u003EL\u00c3\u00b6sung:\u003C\/h3\u003E\r\n\u003Cp\u003EUm den Verlauf der Ableitung zu der gegebenen\u00c2\u00a0Funktion \r\n  `f(x)`\r\n  zu ermitteln, muss die Steigung der Funktion ermittelt werden. In der nachfolgenden Grafik wurde an verschiedenen Stellen die entsprechende Tangente eingezeichnet, mit deren Hilfe man sich die Steigung der Funktion in diesen\u00c2\u00a0Punkten\u00c2\u00a0verdeutlichen kann:\u003C\/p\u003E\r\n\u003Cp\u003E\u003Cimg style=\"border: 0;\" alt=\"ein Graph im Koordinatensystem\" src=\"https:\/\/netmath.vcrp.de\/downloads\/Skripte\/Vorkurs\/HSWildau21\/img\/Ableitungen4.jpg\" width=\"555\" height=\"555\" border=\"0\" \/\u003E\u003C\/p\u003E\r\n\u003Cp\u003EDa es bei dieser Aufgabe nur das Ziel ist, die Gr\u00c3\u00b6\u00c3\u0178enordnung der Steigung an einer bestimmten Stelle im Vergleich zu anderen einzusch\u00c3\u00a4tzen, m\u00c3\u00bcssen keine konkrete Zahlenwerte f\u00c3\u00bcr die Tangentensteigungen ausgerechnet werden. Das geht mit den gegebenen Informationen auch gar nicht ...\u003C\/p\u003E\r\n\u003Cp\u003E\u003Cstrong\u003E\u00c3\u0153berlegungen zu den Tangenten:\u003C\/strong\u003E\u003C\/p\u003E\r\n\u003Cul\u003E\r\n  \u003Cli\u003EDie \u003Cstrong\u003ETangente\u003C\/strong\u003E\r\n    `t1(x)`\r\n    ber\u00c3\u00bchrt die Funktion im Punkt \r\n    `\\left(-\\frac{3}{2} , f\\left(-\\frac{3}{2}\\right)\\right)`\r\n    und ist eine fallende Gerade. Die Steigung von \r\n    `f(x)`\r\n    muss an dieser Stelle also negativ sein.\u003C\/li\u003E\r\n  \u003Cli\u003EDie \u003Cstrong\u003ETangente\u003C\/strong\u003E \r\n    `t2(x)`\r\n    ber\u00c3\u00bchrt die Funktion im Punkt \r\n    `(-1 , f(-1))`\r\n    und ist eine konstante Gerade. Die Steigung von \r\n    `f(x)`\r\n    muss an dieser Stelle also \r\n    `0`\r\n    sein.\u003C\/li\u003E\r\n  \u003Cli\u003EDie \u003Cstrong\u003ETangente\u003C\/strong\u003E \r\n    `t3(x)`\r\n    ber\u00c3\u00bchrt die Funktion im Punkt \r\n    `\\left(-\\frac{1}{2} , f\\left(-\\frac{1}{2}\\right)\\right)`\r\n    und ist eine steigende Gerade. Die Steigung von \r\n    `f(x)`\r\n    muss an dieser Stelle also positiv sein.\u003C\/li\u003E\r\n  \u003Cli\u003EDie \u003Cstrong\u003ETangente\u003C\/strong\u003E \r\n    `t4(x)`\r\n    ber\u00c3\u00bchrt die Funktion im Punkt \r\n    `(0 , f(0))`\r\n    und ist eine konstante Gerade. Die Steigung von \r\n    `f(x)`\r\n    muss an dieser Stelle also \r\n    `0`\r\n    sein.\u003C\/li\u003E\r\n  \u003Cli\u003EDie \u003Cstrong\u003ETangente\u003C\/strong\u003E \r\n    `t5(x)`\r\n    ber\u00c3\u00bchrt die Funktion im Punkt \r\n    `\\left(\\frac{1}{2} , f\\left(\\frac{1}{2}\\right)\\right)`\r\n    und ist eine fallende Gerade. Die Steigung von \r\n    `f(x)`\r\n    muss an dieser Stelle also negativ sein.\u003C\/li\u003E\r\n  \u003Cli\u003EDie \u003Cstrong\u003ETangente\u003C\/strong\u003E \r\n    `t6(x)`\r\n    ber\u00c3\u00bchrt die Funktion im Punkt \r\n    `(1 , f(1))`\r\n    und ist eine konstante Gerade. Die Steigung von \r\n    `f(x)`\r\n    muss an dieser Stelle also \r\n    `0`\r\n    sein.\u003C\/li\u003E\r\n  \u003Cli\u003EDie \u003Cstrong\u003ETangente\u003C\/strong\u003E \r\n    `t7(x)`\r\n    ber\u00c3\u00bchrt die Funktion im Punkt \r\n    `\\left(\\frac{3}{2} , f\\left(\\frac{3}{2}\\right)\\right)`\r\n    und ist eine steigende Gerade. Die Steigung von \r\n    `f(x)`\r\n    muss an dieser Stelle also positiv sein.\u003C\/li\u003E\r\n\u003C\/ul\u003E\r\n\u003Cp\u003E\u003C\/p\u003E\r\n\u003Cul\u003E\r\n  \u003Cli\u003EVergleicht man\u003Cstrong\u003E die beiden fallenden Tangenten\u003C\/strong\u003E \r\n    `t1(x)`\r\n    und \r\n    `t5(x)`\r\n    , stellt man fest, dass \r\n    `t1(x)`\r\n    sehr viel steiler verl\u00c3\u00a4uft als \r\n    `t5(x)`\r\n    . Die Steigung von \r\n    `t1(x)`\r\n    muss also vom Betrag her gr\u00c3\u00b6\u00c3\u0178er sein als die Steigung von \r\n    `t5(x)`\r\n    .\u003C\/li\u003E\r\n  \u003Cli\u003EGleiches gilt f\u00c3\u00bcr \u003Cstrong\u003Edie beiden steigenden Tangenten\u003C\/strong\u003E \r\n    `t3(x)`\r\n    und \r\n    `t7(x)`\r\n    . \r\n    `t7(x)`\r\n    verl\u00c3\u00a4uft deutlich steiler als \r\n    `t3(x)`\r\n    . Die Steigung von \r\n    `t7(x)`\r\n    muss also vom Betrag her gr\u00c3\u00b6\u00c3\u0178er sein als die Steigung von \r\n    `t3(x)`\r\n    .\u003C\/li\u003E\r\n\u003C\/ul\u003E\r\n\u003Cp\u003E\u003Cbr \/\u003E\u00c3\u0153bertr\u00c3\u00a4gt man diese Erkenntnisse in ein Koordinatensystem, erh\u00c3\u00a4lt man eine Kurve \u00c3\u00a4hnlich der in der nachfolgenden Grafik gezeigten:\u003C\/p\u003E\r\n\u003Cp\u003E\u003Cimg style=\"border: 0;\" alt=\"der Graph der Ableitungsfunktion zur vorherigen Funktion\" src=\"https:\/\/netmath.vcrp.de\/downloads\/Skripte\/Vorkurs\/HSWildau21\/img\/Ableitungen5.jpg\" width=\"555\" height=\"555\" border=\"0\" \/\u003E\u003C\/p\u003E\r\n\u003Cp\u003EMehr ist nicht gefragt ...\u003Cbr \/\u003EDiese Aufgabe ist deswegen wichtig, weil Sie sich hier\u00c3\u00bcber einen anderen Blick auf Ableitungen erarbeiten. Dieser hilft zum Beispiel, um berechnete Ableitungen zu \u00c3\u00bcberpr\u00c3\u00bcfen, aber auch im Kontext von Anwendungsaufgaben.\u003C\/p\u003E","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"35":{"uniqueid":1659562489702902,"adddate":1659562489,"lastmoddate":1659563642,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Mengenlehre: Venn-Diagramm beschreiben","qtype":"string","control":"loadlibrary(\"setexp\")\r\n$answerformat=\"setexp\"\r\n$variables=\"A,B,C\"\r\n$exp=setexprand(\"A,B,C\",\"nn,uu,-\",2,1)\r\n$answer=$exp\r\n$v=venn3diagram(\"A,B,C\",$exp)","qcontrol":"","qtext":"Geben Sie einen Ausdruck an, der die rot markierte Fl\u00c3\u00a4che beschreibt.\r\n\r\n$v\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"34":{"uniqueid":1659592746030193,"adddate":1659592746,"lastmoddate":1696748149,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Logik: Wahrheitswertetabellen","qtype":"multipart","control":"loadlibrary(\"logic\")\r\n$anstypes=\"string\"\r\n$answerformat=\"logic\"\r\n$variables=\"p,q,r\"\r\n$ops=\"and,or,implies,iff\"\r\n$exp=logicrand($variables,$ops,2,2)\r\n$answer=$exp\r\n$tab=truthtable($exp,2,FALSE)\r\n","qcontrol":"","qtext":"Geben Sie einen logischen Ausdruck in den Aussagenvariablen `p,q` und `r` an, der die folgende Wahrheitswertetabelle beschreibt.\r\n\r\n$tab\r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"33":{"uniqueid":1659596583994702,"adddate":1659596583,"lastmoddate":1659597957,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Chemie-Frage","qtype":"chemeqn","control":"$answerformat = \"reaction\"\r\n\r\n$answer = \"2H_2 + O_2 -\u003E 2H_2O\"\r\n\r\n$variables = \"H,O\"","qcontrol":"","qtext":"Geben Sie die chemische Reaktion an, die Wasser aus zwei Gasen erzeugt.\r\n\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"36":{"uniqueid":1670351082659965,"adddate":1670351082,"lastmoddate":1700431661,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Kettenregel mit Funktionsvariablen","qtype":"numfunc","control":"$variable=\"x,f(),f'()\"\r\n\r\n$answer=\"4x f(x^2+1) f'(x^2+1)\"\r\n","qcontrol":"","qtext":"`f` sei eine Funktion mit der Ableitung `f'`. Geben Sie die Ableitung der Funktion `f(x^2+1)^2+1` an.\r\n\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"37":{"uniqueid":1682544011227180,"adddate":1682544011,"lastmoddate":1722951348,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Demo: Zeichenkette in die Zwischenablage kopieren","qtype":"essay","control":"loadlibrary(\"chatter\")\r\n$displayformat=\"editor\"\r\n$question=\"In einem Schaltkreis sind die Widerst\u00c3\u00a4nde `R_1` und `R_2` parallel geschaltet. Erk\u00c3\u00a4ren Sie, wie Sie den Widerstand der Kombination von `R_1` und `R_2` berechnen.\"\r\n$questionTex=\"In einem Schaltkreis sind die Widerst\u00c3\u00a4nde \\$R_1\\$ und \\$R_2\\$ parallel geschaltet. Erkl\u00c3\u00a4ren Sie, wie Sie den Widerstand der Kombination von \\$R_1\\$ und \\$R_2\\$ berechnen.\"\r\n$helptext=\"\"\r\n\r\nif (stuansready($stuanswers,$thisq,null)) {\r\n  \/\/ essayText wandelt Zeichenketten wie in einem Essay-Eingabefeld in einfachen Text mit LaTeX um.\r\n  $ans=essayText(getstuans($stuanswers,$thisq))\r\n  $request=\"Kommentiere folgende Antwort auf die Frage \\\"$questionTex\\\": \\n\\n Antwort: $ans\"\r\n  \/\/ copybutton wird in der Bibliothek chatter definiert.\r\n  $helptext=copyButton($request,\"Klicke hier f\u00c3\u00bcr eine Kommentaranfrage\",\"In der Zwischenablage befindet sich nun eine Kommentaranfrage, die Sie z.B. in einen Chat einf\u00c3\u00bcgen k\u00c3\u00b6nnen\",\"Tut mir leid, es gab einen Fehler beim Kopieren Ihrer Antwort.\")\r\n}","qcontrol":"","qtext":"$question\r\n\r\n$answerbox\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"38":{"uniqueid":1687850673842161,"adddate":1687850673,"lastmoddate":1687851202,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Frage dynamisch modifizieren","qtype":"multipart","control":"$anstypes = \"choices,number,number\"\r\n\r\n$a,$b,$c = diffrands(2,9,3)\r\n\r\n$questions[0] = array(\"Zuerst ausmultiplizieren\", \"Zuerst addieren\")\r\n$answer[0]=0\r\n\r\n\r\n$answerformat[1]=\"list\"\r\n$temp1 = $a*$b\r\n$temp2 = $a*$c\r\n$part2text = \"Geben Sie durch ein Komma getrennt die zwei Produkte an, die Sie durch Ausmultiplizieren erhalten.\"\r\n$answer[1]=\"$temp1,$temp2\"\r\n$part3text = \"Jetzt berechnen Sie die Summe:\"\r\n\r\n\r\n$stu = getstuans($stuanswers,$thisq,0)\r\nif($stu!=null){\r\n  $answer[0]=$stu\r\n  if($stu!=0){\r\n    $part2text = \"Was ist die Summe?\"\r\n    $answer[1] = $b+$c\r\n    $part3text = \"Multiplizieren Sie jetzt:\"\r\n  }\r\n}\r\n\r\n\r\n$answer[2]=$a($b+$c)\r\n\r\n$answeights = \"0.001,0.5,0.499\"","qcontrol":"","qtext":"Um $a($b + $c) zu berechnen k\u00c3\u00b6nnen Sie zuerst ausmultiplizieren oder addieren. Was m\u00c3\u00b6chten Sie tun?\r\n\r\n$answerbox[0]\r\n\r\n\r\n\/\/\/\r\n\r\n\r\n$part2text\r\n\r\n\r\n$answerbox[1]\r\n\r\n\r\n\/\/\/\r\n\r\n\r\n$part3text\r\n\r\n$answerbox[2]\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"40":{"uniqueid":1719306216941174,"adddate":1719306216,"lastmoddate":1738836466,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Aufgaben-Helfer ChatGPT","qtype":"numfunc","control":"\/\/ Frage 10741 l\u00c3\u00a4dt die erforderliche Bibliothek (chatter) und definiert die URL des Chatbots\r\n\/\/ Dadurch bleibt die Frage g\u00c3\u00bcltig, auch wenn sich der Chatbot \u00c3\u00a4ndern sollte.\r\nincludecodefrom(EID46)\r\n\r\n$a=rand(2,6);$b=rand(2,4);$c=rand(2,9);$d=rand(3,6);\r\n$f=\"$a*($b*x^2+$c)^$d*e^x\";\r\n\/\/ Richtige L\u00c3\u00b6sung\r\n$g=\"2*($b*x^2 + $c)^($d - 1)*$a*$b*$d*x*e^x + ($b*x^2 + $c)^$d*$a*e^x\"\r\n$answer=$g\r\n\r\n\/\/ Prompt mit Markdown und LaTeX definieren\r\n\/\/ Chatbots verstehen kein ASCIIMath, deshalb sollten Formeln f\u00c3\u00bcr den Prompt nach LaTeX konvertiert werden\r\n\/\/ Das Makro asccimath2tex wird in der inkludierten Bibliothek definiert Es schlie\u00c3\u0178t die Formel in $-Zeichen ein.\r\n$ff=asciimath2tex($f)\r\n\r\n\/\/ F\u00c3\u00bcr die Verwendung als URL-Parameter muss der Promt URL-codiert werden; z.B. werden Leerzeichen durch %20 ersetzt.\r\n$prompt=rawurlencode(\"Bilde die Ableitung von $ff .\")\r\n\r\n\/\/ $AufgabenhelferURL wird in der inkludierten Aufgabe definiert. Hier wird der URL-codierte Prompt als Parameter \"prompt\" angef\u00c3\u00bcgt.\r\n$url=\"$AufgabenhelferURL?prompt=$prompt\"\r\n\r\n\/\/Schaltfl\u00c3\u00a4che f\u00c3\u00bcr das Aufrufen des Hilfsangebots\r\n$button=formpopup(\"KI um Hilfe bitten\",$url,800,600,\"button\")\r\n\r\n\/\/ Das Hilfsangebot wird erst nach dem ersten Fehlversuch angezeigt.\r\n$hints[1]=\"$button \u003Cb\u003EAchtung:\u003C\/b\u003EKI ist unzuverl\u00c3\u00a4ssig!\"\r\n","qcontrol":"","qtext":"Bilde die Ableitung von `$f`.\r\n\r\nVersuche zun\u00c3\u00a4chst, selbst die L\u00c3\u00b6sung zu finden. Wenn Du es nicht schaffst, kannst Du Hilfe von einer K\u00c3\u00bcnstlichen Intelligenz erhalten.\r\n\r\n$answerbox\r\n\r\n$hintloc\r\n","answer":"","hasimg":1,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"Dahn,Ingo; dahn,Ingo, mb Dahn,Ingo","otherattribution":"","a11yalttype":0,"a11yalt":0,"qimgs":{"0":{"var":"","filename":"https:\/\/netmath.vcrp.de\/IMathAS\/assessment\/qimages\/logoVcrpGross.png","alttext":""}},"dependencies":{"0":46}},"46":{"uniqueid":1721129537201894,"adddate":1721129537,"lastmoddate":1760264537,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Code f\u00c3\u00bcr Chatter f\u00c3\u00bcr Aufgaben-Helfer, Anwender und Freitext-Kommentator zum Einbinden in andere Fragen","qtype":"number","control":"\/\/ Dieser Code kann mit includecodefrom(EID46) in andere Fragen eingebunden werden.\r\n\r\n\r\nloadlibrary(\"chatter\")\r\n\r\n\r\n$AufgabenhelferURL=\"https:\/\/chatsite.dahn-research.de\/cgeneral\/assistants\/Aufgaben-Helfer\"\r\n$FreitextkommentatorURL=\"https:\/\/chatsite.dahn-research.de\/cgeneral\/tasks\/Freitext%20kommentieren\"\r\n$AnwenderURL=\"https:\/\/chatsite.dahn-research.de\/cgeneral\/tasks\/Ein%20Konzept%20anwenden\"\r\n$AufgabenloeserURL=\"https:\/\/chatsite.dahn-research.de\/cgeneral\/assistants\/Aufgaben-L%C3%B6ser\"\r\n$AnwendungsaufgabeURL=\"https:\/\/chatsite.dahn-research.de\/cgeneral\/tasks\/Anwendungsaufgabe%20erstellen\"\r\n\/\/ $FehlerteufelURL=\"https:\/\/chatsite.dahn-research.de\/cgeneral\/assistants\/Fehlerteufel\"\r\n$VorkursHelferURL=\"https:\/\/chatsite.dahn-research.de\/cgeneral\/assistants\/Kurs-Helfer?Wissensbasis=Vorkurs\"\r\n","qcontrol":"","qtext":"Dies ist keine echte Frage","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"41":{"uniqueid":1721225837272228,"adddate":1721225837,"lastmoddate":1738836678,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Ein Beispiel f\u00c3\u00bcr eine Freitext- (Essay-) Frage mit KI-Unterst\u00c3\u00bctzung. Nach dem Einreichen eines Freitextes wird angeboten, ihn durch eine KI kommentieren zu lassen.","qtype":"essay","control":"\/\/ Frage 10741 l\u00c3\u00a4dt die erforderliche Bibliothek (chatter) und definiert die URL des Chatbots\r\n\/\/ Dadurch bleibt die Frage g\u00c3\u00bcltig, auch wenn sich der Chatbot \u00c3\u00a4ndern sollte.\r\nincludecodefrom(EID46)\r\n\r\n$displayformat=\"editor\"\r\n\/\/ Nur nichtnegative Koeffizienten, wenigstens Grad 2\r\n$c1=rands(0,9,4) where ($c1[2]!=0)\r\n\/\/ Leitkoeffizient soll \u00c3\u00b6fter 0 sein\r\nif ($c1[3] \u003E 5) {\r\n  $c1[3]=0\r\n}\r\n$c2=rands(0,9,4) where ($c2[2]!=0)\r\nif ($c2[3] \u003E 5) {\r\n  $c2[3]=0\r\n}\r\n$f1=polymakepretty(\"$c1[3]x^3+$c1[2]x^2+$c1[1]x+$c1[0]\"); $f2=\"x\u00c2\u00b3\"\r\n$f2=polymakepretty(\"$c2[3]x^3+$c2[2]x^2+$c2[1]x+$c1[0]\")\r\n$f1_tex=asciimath2tex(\"f_1=$f1\")\r\n$f2_tex=asciimath2tex(\"f_2=$f2\")\r\n$lim=\"x rarr oo\"\r\n$lim_tex=asciimath2tex($lim)\r\n$frage=\"Welche der Funktionen $f1_tex und $f2_tex w\u00c3\u00a4chst schneller f\u00c3\u00bcr $lim_tex?\r\nBegr\u00c3\u00bcnde Deine Antwort.\"\r\n$frage_enc=rawurlencode($frage)\r\n$helptext=\"\"\r\n\r\n\/\/$FreitextkommentatorURL wird in der inkludierten Aufgabe definiert\r\n$chaturl=$FreitextkommentatorURL\r\nif (stuansready($stuanswers,$thisq,null)) {\r\n  $antwort=getstuans($stuanswers,$thisq)\r\n  $antwortText=essayText($antwort)\r\n  $antwort_enc=rawurlencode($antwortText)\r\n  $request=\"$chaturl?Frage=$frage_enc&Antwort=$antwort_enc\"\r\n  $button=formpopup(\"Kommentar der KI zu Deiner Antwort\",$request,800,600,\"button\",true)\r\n  $helptext=\"$button \u003Cb\u003EAchtung:\u003C\/b\u003E KI ist unzuver\u00c3\u00a4ssig!\"\r\n}","qcontrol":"","qtext":"Welche der Funktionen `f_1=$f1` und `f_2=$f2` w\u00c3\u00a4chst schneller f\u00c3\u00bcr `$lim`?\r\n\r\nBegr\u00c3\u00bcnde Deine Antwort.\r\n\r\n$answerbox\r\n\r\nDu kannst Deine Antwort zur Kontrolle von einer KI bewerten lassen, nachdem Du sie eingereicht hast.\r\n\r\n$hintloc","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0,"dependencies":{"0":46}},"42":{"uniqueid":1725005572410758,"adddate":1725005572,"lastmoddate":1738836760,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Exponentialgleichung bestimmen mit KI-Link zu Anwendungen f\u00c3\u00bcr Exponentialgleichungen","qtype":"multipart","control":"\/\/ Frage 10741 l\u00c3\u00a4dt die erforderliche Bibliothek (chatter) und definiert die URL des Chatbots\r\n\/\/ Dadurch bleibt die Frage g\u00c3\u00bcltig, auch wenn sich der Chatbot \u00c3\u00a4ndern sollte.\r\nincludecodefrom(EID46)\r\n\r\n$anstypes =array(\"number\",\"number\")\r\n\r\n$a=nonzerorands(-5,5,2)\r\n$c=$a[0]*$a[1]\r\n\r\n$answer[0]=$a[0]\r\n$answer[1]=$a[1]\r\n\r\n$Anzahl=2\r\n$Konzept=\"Exponentialgleichungen\"\r\n$Gebiet=\"den Naturwissenschaften\"\r\n\/\/ $AnwenderURL wird in der inkludierten Aufgabe definiert.\r\n$url=\"$AnwenderURL?Anzahl=$Anzahl&Konzept=$Konzept&Gebiet=$Gebiet\"\r\n\/\/Schaltfl\u00c3\u00a4che f\u00c3\u00bcr das Aufrufen des Hilfsangebots\r\n$button=formpopup(\"Wozu ist das gut?\",$url,800,600,\"button\")","qcontrol":"","qtext":"\u003Cp\u003EBestimmen Sie die allgemeine Exponentialfunktion der Form `f(x)=b*a^x`, die durch die Punkte P(0,$a[1]) und Q(1, $c) geht.\u003C\/p\u003E\r\n\u003Cp\u003Ea=$answerbox[0]\u003C\/p\u003E\r\n\u003Cp\u003Eb=$answerbox[1]\u003C\/p\u003E\r\n\r\n$button","answer":"","hasimg":0,"extref":"read!!https:\/\/netmath.vcrp.de\/downloads\/Einheiten\/Gaa\/Hilfen\/ExponentialUndLogarithmusfunktionen\/Q3.PNG!!0","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"Gaa,Julia, mb dahn,Ingo","otherattribution":"","a11yalttype":0,"a11yalt":0,"dependencies":{"0":46}},"43":{"uniqueid":1738694092142058,"adddate":1738694092,"lastmoddate":1756283062,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Musterl\u00c3\u00b6sung mit KI erzeugen- eine Aufgabe mit einem Button f\u00c3\u00bcr deren L\u00c3\u00b6sung","qtype":"number","control":"\/*\r\n* Diese Aufgabe zeigt, wie man KI einsetzen kann, um eine ausf\u00c3\u00bchrliche Musterl\u00c3\u00b6sung zu erzeugen, die man editieren und der Aufgabe beif\u00c3\u00bcgen kann.\r\n* Der Button zur Erzeugung der L\u00c3\u00b6sung sollte f\u00c3\u00bcr Studierende nicht angezeigt werden!\r\n* Die erzeugte L\u00c3\u00b6sung muss IMMER \u00c3\u00bcberpr\u00c3\u00bcft und f\u00c3\u00bcr die Darstellung in IMathAS angepasst werden.\r\n* Das hier verwendete Beispiel bereitet vielen KI-Systemen Probleme durch die Bereitstellung \u00c3\u00bcberfl\u00c3\u00bcssiger Informationen\r\n*\/\r\n\r\n\/\/ Frage 10741 l\u00c3\u00a4dt die erforderliche Bibliothek (chatter) und definiert die URL des Chatbots\r\n\/\/ Dadurch bleibt die Frage g\u00c3\u00bcltig, auch wenn sich der Chatbot \u00c3\u00a4ndern sollte.\r\nincludecodefrom(EID46)\r\n\r\n$Kuchen=rand(3,7)\r\n$Jungen, $Maedchen =rands(2,6,2) where ($Jungen+$Maedchen \u003E $Kuchen)\r\n\r\n$Kinder=$Jungen+$Maedchen\r\n$answer=$Kuchen*($Kuchen-1)^($Kinder-1)\r\n\r\n\/\/ Erzeugung einer Musterl\u00c3\u00b6sung\r\n\/\/ F\u00c3\u00bcr die Verwendung als URL-Parameter muss der Promt URL-codiert werden; z.B. werden Leerzeichen durch %20 ersetzt.\r\n$prompt=rawurlencode(\"An einer Feier nehmen $Maedchen M\u00c3\u00a4dchen und $Jungen Jungen teil. Es gib $Kuchen verschiedene Sorten von Kuchen. Alle Kinder nehmen nacheinander je ein St\u00c3\u00bcck Kuchen.\r\nWie viele M\u00c3\u00b6glichkeiten der Verteilung der Kuchensorten auf die Kinder gibt es, wenn jedes Kind eine andere Sorte w\u00c3\u00a4hlt, als das unmittelbar vorhergehende?\")\r\n\r\n\/\/ $AufgabenloeserURL wird in der inkludierten Aufgabe definiert. Hier wird der URL-codierte Prompt als Parameter \"prompt\" angef\u00c3\u00bcgt.\r\n$url=\"$AufgabenloeserURL?prompt=$prompt\"\r\n\r\n\/\/Schaltfl\u00c3\u00a4che f\u00c3\u00bcr das Aufrufen des Hilfsangebots\r\n$button=formpopup(\"Musterl\u00c3\u00b6sung erzeugen\",$url,800,600,\"button\")\r\n\r\n\/* Die Musterk\u00c3\u00b6sung kann man \u00c3\u00bcberpr\u00c3\u00bcfen, anpassen und als Musterl\u00c3\u00b6sung in die IMathAS-Aufgabe eingeben.\r\n* Ist die erzeugte Musterl\u00c3\u00b6sung korrekt, so kann man sie auch wie folgt direkt bereitstellen.\r\n* 1. Chat mit Hilfe des Buttons auf der Chatseite speichern\r\n* 2. Den als HTML-Seite gespeicherten Chat auf einer \u00c3\u00b6ffentlich zug\u00c3\u00a4nglichen Seite bereitstellen\r\n* 3. Die URL der Seite als Hinweis in der IMathAS-Aufgabe verwenden oder mit Hilfe von $hints anzeigen lassen.\r\n* Diese Aufgabe verwendet beide M\u00c3\u00b6glichkeiten.\r\n*\/\r\n\r\n$hints[1]=\"So \u003Ca href='https:\/\/dahn-research.eu\/imathas\/kuchen.html' target='_blank'\u003El\u00c3\u00b6st die KI\u003C\/a\u003E eine \u00c3\u00a4hnliche Aufgabe.\"\r\n","qcontrol":"","qtext":"An einer Feier nehmen $Maedchen M\u00c3\u00a4dchen und $Jungen Jungen teil. Es gib $Kuchen verschiedene Sorten von Kuchen. Alle Kinder nehmen nacheinander je ein St\u00c3\u00bcck Kuchen.\r\nWie viele M\u00c3\u00b6glichkeiten der Verteilung der Kuchensorten auf die Kinder gibt es, wenn jedes Kind eine andere Sorte w\u00c3\u00a4hlt, als das unmittelbar vorhergehende?\r\n\r\nEs gibt $answerbox M\u00c3\u00b6glichkeiten.\r\n\r\n$button\r\n\r\n$hintloc","answer":"","hasimg":0,"extref":"read!!https:\/\/dahn-research.eu\/imathas\/kuchen.html!!0!!Musterl\u00c3\u00b6sung","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0,"dependencies":{"0":46}},"44":{"uniqueid":1755596431767558,"adddate":1755596431,"lastmoddate":1755599503,"ownerid":2,"author":"Dahn,Ingo","userights":2,"description":"Tangente an eine Parabel in einem bestimmten Punkt bestimmen.\r\nMit KI-Link zu analoger Anwendungsaufgabe","qtype":"multipart","control":"$anstypes=array(\"calculated\",\"calculated\",\"calculated\",\"string\")\r\n\r\n\/\/ Frage 10741 l\u00c3\u00a4dt die erforderliche Bibliothek (chatter) und definiert die URL des Chatbots\r\n\/\/ Dadurch bleibt die Frage g\u00c3\u00bcltig, auch wenn sich der Chatbot \u00c3\u00a4ndern sollte.\r\nincludecodefrom(EID46)\r\n\r\n\/\/ Eingabe des Fachgebiets gibt keine Punkte:\r\n\/\/ Die Aufgabe wurde von einer existierenden Aufgabe angepasst; das Fachgebiet wird im Teil mit der Nummer 3 erfasst.\r\n$answeights=array(1,1,1,0)\r\n\r\n$scoremethod[3]=\"takeanythingorblank\" \/\/ der erste Teil nimmt das Fachgebiet entgegen.\r\n\r\n$a1 = rrand(2,4,1);\r\n$b1 = rrand(2,7,1);\r\n$c1 = rrand(2,7,1);\r\n$x1 = rrand(-5,5,1);\r\n$y1 = $a1*$x1*$x1 - $b1*$x1+$c1;\r\n$m1 = 2*$a1*$x1 - $b1;\r\n\r\n$ans1 = $m1;\r\n\r\n\r\n$ans2 = $m1;\r\n\r\n\r\n$ans3 = $y1 -$m1*$x1;\r\n\r\n$answerboxsize[0]=20\r\n$answerboxsize[1]=20\r\n$answerboxsize[2]=20\r\n\r\n$answer[0]=$ans1\r\n$answer[1]=$ans2\r\n$answer[2]=$ans3\r\n\r\n$f=asciimath2tex(\"f(x) = $a1 x^2 - $b1 x + $c1\")\r\n$p=asciimath2tex(\"( $x1 , $y1 )\")\r\n$Aufgabe=\"Bestimme die Tangente an die Parabel $f im Punkt $p.\"\r\n$AufgabeEncoded=rawurlencode($Aufgabe)\r\n$Gebiet=\"den Naturwissenschaften\"\r\nif (stuansready($stuanswers,$thisq,3)) {\r\n  $Gebiet=getstuans($stuanswers,$thisq,3)\r\n  if ($Gebiet != \"\") {\r\n    \/\/ $AnwendungsaufgabeURL wird in der inkludierten Aufgabe definiert.\r\n\t\t$url=\"$AnwendungsaufgabeURL?Fachgebiet=$Gebiet&Aufgabe=$AufgabeEncoded\"\r\n\t\t\/\/Schaltfl\u00c3\u00a4che f\u00c3\u00bcr das Aufrufen des Hilfsangebots\r\n\t\t$button=formpopup(\"Eine \u00c3\u00a4hnliche Aufgabe aus dem Gebiet $Gebiet\",$url,800,600,\"button\")\r\n    $message=\"\u003Cp\u003E\u003Cb\u003EACHTUNG:\u003C\/b\u003E Anwendungsaufgabe ist KI-generiert - kann Fehler enthalten!\u003C\/p\u003E\u003Cp\u003EIst die Aufgabe plausibel? Falls nicht: Kannst Du sie korrigieren?\"\r\n  }\r\n}\r\n","qcontrol":"","qtext":"Sei ` f(x) = $a1 x^2 - $b1 x + $c1 `. Bestimme ` f'( $x1 ) `.\r\n\r\n\r\nBestimme nun die Tangente an die Parabel ` y = $a1 x^2 - $b1 x + $c1 `\r\nim Punkt ` ( $x1 , $y1 ) `.\r\n\r\n\r\nDie Gleichung der Tangente kann geschrieben werden als ` y = mx+b `.\r\n\r\n` m =` $answerbox[1]\r\n\r\nund \u003Cbr\/\u003E\r\n` b =` $answerbox[2]\r\n\r\n\u003Cp\u003E\u003Cb\u003EWozu brauche ich so etwas? W\u00c3\u00a4hle Dein Fachgebiet f\u00c3\u00bcr eine \u00c3\u00a4hnliche Anwendungsaufgabe oder lasse das Feld leer, um diesen Teil zu \u00c3\u00bcbersprinegn!\u003C\/b\u003E\u003C\/p\u003E\r\n\u003Cp\u003E$answerbox[3]\u003C\/p\u003E\r\n\r\n$button $message\r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"Geier,Maximilian, mb Lehmann,Julian","otherattribution":"","a11yalttype":0,"a11yalt":0,"dependencies":{"0":46}}}}