alty":"9999","category":"","regen":0,"showans":"0","showhints":-1,"extracredit":0,"fixedseeds":null},"40":{"questionsetid":40,"points":9999,"attempts":9999,"penalty":"9999","category":"","regen":0,"showans":"0","showhints":-1,"extracredit":0,"fixedseeds":null},"41":{"questionsetid":41,"points":9999,"attempts":9999,"penalty":"9999","category":"","regen":0,"showans":"0","showhints":-1,"extracredit":0,"fixedseeds":null},"42":{"questionsetid":42,"points":9999,"attempts":9999,"penalty":"9999","category":"","regen":0,"showans":"0","showhints":-1,"extracredit":0,"fixedseeds":null},"43":{"questionsetid":43,"points":9999,"attempts":9999,"penalty":"9999","category":"","regen":0,"showans":"0","showhints":-1,"extracredit":0,"fixedseeds":null},"44":{"questionsetid":44,"points":9999,"attempts":9999,"penalty":"9999","category":"","regen":0,"showans":"0","showhints":-1,"extracredit":0,"fixedseeds":null}},"questionset":{"0":{"uniqueid":1330709521431601,"adddate":1344427190,"lastmoddate":1681592469,"ownerid":2,"author":"Dahn,Ingo, mb dahn,Ingo","userights":2,"description":"Br\u00c3\u00bcche vereinfachen\r\nDo0","qtype":"multipart","control":"$anstypes=array(\"numfunc\",\"numfunc\")\r\n$variables[0]=\"a,b,c,z\"\r\n\r\n$b = rand(2,9)\r\n\r\n$c=$b*$b\r\n\r\n$eqn[0] = \"`(z - $b)(a\/(z^2-$b z) - 1\/(z^2-$c))`\"\r\n\r\n$simp[0] = \"`a\/z - 1\/(z+$b)`\"\r\n\r\n$answer[0] = $simp[0]\r\n\r\n$requiretimes[0] = \"a,\u003C3,-,=1,^,\u003C1\"\r\n\r\n$showanswer[0] = $simp[0]\r\n\r\n$variables[1] = \"a,c\"\r\n$eqn[1] = \"`(ac^5)\/(a^2+2a+1):(ac^2)\/(a+1)`\"\r\n$simp[1] = \"`(c^3)\/(a+1)`\"\r\n$requiretimes[1] = \"^,=1,+,=1\"\r\n$answer[1]=$simp[1]\r\n$showanswer[1]= $simp[1]","qcontrol":"","qtext":"\u003Ch2\u003EVereinfache die folgenden Ausdr&uuml;cke.\u003C\/h2\u003E\r\n\u003Cp\u003Ea) $eqn[0] = $answerbox[0]\u003C\/p\u003E\r\n\u003Cp\u003Eb) $eqn[1] = $answerbox[1]\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"9":{"uniqueid":1332511252077287,"adddate":1344429111,"lastmoddate":1356680911,"ownerid":2,"author":"Dahn,Ingo, mb dahn,Ingo","userights":2,"description":"Unendliche Vereinigung\/Durchschnitt\r\nAus Wolter, Dahn: Analysis Individuell","qtype":"multipart","control":"$anstypes=array(\"essay\",\"essay\")\r\n$displayformat[0]=\"editor\"\r\n$displayformat[1]=\"editor\"\r\n\r\n\r\n$answerboxsize[0]=\"5,50\"\r\n$answerboxsize[1]=\"5,50\"\r\n\r\n$eqn[0] = \"`C(X uu Y) = C(X) nn C(Y)`\"\r\n$eqn[1] = \"`C(X nn Y) = C(X) uu C(Y)`\"\r\n\r\n\r\n$hidetips=true","qcontrol":"","qtext":"\u003Ch3\u003EEs sei \u003Cspan class=\"AM\" title=\"&lt;span class=&quot;AM&quot;&gt;M&lt;\/span&gt; \"\u003E`M`\u003C\/span\u003E eine Menge. F&uuml;r&nbsp;\u003Cspan class=\"AM\" title=\"X sube M\"\u003E`X sube M`\u003C\/span\u003E sei stets&nbsp;\u003Cspan class=\"AM\" title=\"C(X)\"\u003E`C(X)`\u003C\/span\u003E das Komplement von \u003Cspan class=\"AM\" title=\"X\"\u003E`X`\u003C\/span\u003E bez. \u003Cspan class=\"AM\" title=\"M\"\u003E`M`\u003C\/span\u003E . Weiterhin sei \u003Cspan class=\"AM\" title=\"S={X_i : i in I}\"\u003E`S={X_i : i in I}`\u003C\/span\u003E&nbsp; ein System von Mengen mit \u003Cspan class=\"AM\" title=\"X_i sube M\"\u003E`X_i sube M`\u003C\/span\u003E .\r\n\u003Cp\u003EBeweise die folgenden Aussagen.\u003C\/h3\u003E\r\n\u003Cem\u003EHinweis: Verwende im mathematischen Modus (\u003Cb\u003E`sum +`\u003C\/b\u003E)die folgenden Zeichen um Symbole einzugeben.\u003C\/em\u003E\r\n\u003Ctable\u003E\r\n \u003Ctr\u003E\r\n    \u003Cth\u003ESymbol\u003C\/th\u003E\u003Cth\u003EEingabe\u003C\/th\u003E\r\n \u003C\/tr\u003E\r\n \u003Ctr\u003E\r\n  \u003Ctd\u003E`in`\u003C\/td\u003E\u003Ctd\u003Ein\u003C\/td\u003E\r\n \u003C\/tr\u003E\r\n \u003Ctr\u003E\r\n  \u003Ctd\u003E`uu`\u003C\/td\u003E\u003Ctd\u003Euu\u003C\/td\u003E\r\n \u003Ctr\u003E\r\n  \u003Ctd\u003E`nn`\u003C\/td\u003E\u003Ctd\u003Enn\u003C\/td\u003E\r\n \u003C\/tr\u003E\r\n \u003Ctr\u003E\r\n  \u003Ctd\u003E`X_i`\u003C\/td\u003E\u003Ctd\u003EX_i\u003C\/td\u003E\r\n \u003C\/tr\u003E\r\n \u003Ctr\u003E\r\n  \u003Ctd\u003E`uuu_{i in I}`\u003C\/td\u003E\u003Ctd\u003Euuu_{i in I}\u003C\/td\u003E\r\n \u003C\/tr\u003E\r\n \u003Ctr\u003E\r\n  \u003Ctd\u003E`nnn_{i in I}`\u003C\/td\u003E\u003Ctd\u003Ennn_{i in I}\u003C\/td\u003E\r\n \u003C\/tr\u003E\r\n\u003C\/table\u003E\r\n\u003Cp\u003E(a) \u003Cspan class=\"AM\" title=\"C(uuu_{i in I} X_i) = nnn_{i in I} C(X_i)\"\u003E`C(uuu_{i in I} X_i) = nnn_{i in I} C(X_i).`\u003C\/span\u003E\u003C\/p\u003E\r\n\u003Cp\u003E$answerbox[0]\u003C\/p\u003E\r\n\u003Cp\u003E(b) \u003Cspan class=\"AM\" title=\"C(nnn_{i in I} X_i) = uuu_{i in I} C(X_i)\"\u003E`C(nnn_{i in I} X_i) = uuu_{i in I} C(X_i)`\u003C\/span\u003E .\u003C\/p\u003E\r\n\u003Cp\u003E$answerbox[1]\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"7":{"uniqueid":1334300205179515,"adddate":1344429111,"lastmoddate":1680081159,"ownerid":2,"author":"Dahn,Ingo, mb dahn,Ingo","userights":2,"description":"Megenlehre Beweis 1\r\nAus Wolter, Dahn: Analysis Individuell","qtype":"multipart","control":"$anstypes=array(\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\",\"string\")\r\n$li = \"X nn (Y uu Z)\"\r\n$re = \"(X nn Y) uu (X nn Z)\"\r\n$answer[0] = $li\r\n$strflags[0] = \"remove_whitespace=1\"\r\n$answer[1] = $re\r\n$strflags[1] = \"remove_whitespace=1\"\r\n$answer[2]= $li\r\n$strflags[2] = \"remove_whitespace=1\"\r\n$answer[3]=$li\r\n$strflags[3] = \"remove_whitespace=1\"\r\n$answer[4]=\"Y uu Z\"\r\n$strflags[4] = \"remove_whitespace=1\"\r\n$answer[5]=\"x in Z\"\r\n$strflags[5] = \"remove_whitespace=1\"\r\n$answer[6]=\"x in Y\"\r\n$strflags[6] = \"remove_whitespace=1\"\r\n$answer[7]=\"x in X nn Y\"\r\n$strflags[7] = \"remove_whitespace=1\"\r\n$answer[8]=$re\r\n$strflags[8] = \"remove_whitespace=1\"\r\n$answer[9]=$re\r\n$strflags[9] = \"remove_whitespace=1\"\r\n$answer[10]= \"x in X\"\r\n$strflags[10] = \"remove_whitespace=1\"\r\n$answer[11]= \"x in X nn Z\"\r\n$strflags[11] = \"remove_whitespace=1\"\r\n$answer[12]=\"x in Y\"\r\n$strflags[12] = \"remove_whitespace=1\"\r\n$answer[13]=\"x in Y uu Z\"\r\n$strflags[13] = \"remove_whitespace=1\"\r\n$answer[14]=\"x in X nn (Y uu Z)\"\r\n$strflags[14] = \"remove_whitespace=1\"\r\n\r\n$displayformat=\"usepreview\"","qcontrol":"","qtext":"\u003Ch3\u003EVervollst\u00c3\u00a4ndige den folgenden Beweis der Gleichung `X nn (Y uu Z) = (X nn Y) uu (X nn Z)`.\u003C\/h3\u003E\r\n\u003Cem\u003EHinweis: Verwende die folgenden Zeichen um Formeln einzugeben.\u003C\/em\u003E\r\n\u003Ctable\u003E\r\n  \u003Ctr\u003E\r\n    \u003Cth\u003ESymbol\u003C\/th\u003E\u003Cth\u003EEingabe\u003C\/th\u003E\r\n  \u003C\/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E`in`\u003C\/td\u003E\u003Ctd\u003Ein\u003C\/td\u003E\r\n  \u003C\/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E`uu`\u003C\/td\u003E\u003Ctd\u003Euu\u003C\/td\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E`nn`\u003C\/td\u003E\u003Ctd\u003Enn\u003C\/td\u003E\r\n  \u003C\/tr\u003E\r\n\u003C\/table\u003E\r\n\u003Cp\u003E\r\n  Wir zeigen zun\u00c3\u00a4chst\r\n\u003Col\u003E\r\n  \u003Cli\u003E $answerbox[0] `sube (X nn Y) uu (X nn Z)`und dann \u003C\/li\u003E\r\n  \u003Cli\u003E $answerbox[1] ` sube ` $answerbox[2].\u003C\/li\u003E\r\n\u003C\/ol\u003E\r\n\u003Cp\u003E\r\n  Sei `x in ` $answerbox[3] beliebig gew\u00c3\u00a4hlt. Dann ist `x in X` und `x in ` $answerbox[4]. Wir nehmen an, dass `x in Y`ist. Der Fall $answerbox[5] wird dann analog behandelt.\r\n\u003C\/p\u003E\u003Cp\u003E\r\n  Da `x in X`und $answerbox[6] ist, ist $answerbox[7] und damit erst recht `x in ` $answerbox[8]. Damit ist (1.) bewiesen.\r\n\u003C\/p\u003E\u003Cp\u003E\r\n  Sei umgekehrt `x in ` $answerbox[9] beliebig gew\u00c3\u00a4hlt, etwa $answerbox[10]` nn Y`. Der Fall $answerbox[11] wird analog behandelt. Damit ist nun sowohl `x in X`als auch $answerbox[12], also erst recht $answerbox[13] und damit $answerbox[14], was (2.) und damit die Behauptung beweist.\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"1":{"uniqueid":1335070086110395,"adddate":1344429111,"lastmoddate":1619726122,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Graph-Beispiel (einseitige punktierte Grenzwerte) (copy by Ingo dahn)","qtype":"multipart","control":"$anstypes = listtoarray(\"number,number,number,number\")\r\n\r\n\/\/for each graph, it's:\r\n\/\/function,color,xmin,xmax,startmark,endmark\r\n$graphs[0] = \"-x-5,black,-5,-1,,closed\"\r\n$graphs[1] = \"-2x+3,black,-1,2,open\"\r\n$graphs[2] = \"-2x+3,black,2,5,open\"\r\n\/\/last one is really just a dot, but we define it as\r\n\/\/a function\r\n$graphs[3] = \"2,black,2,2,closed\"\r\n\r\n\/\/graphs,xmin,xmax,ymin,ymax,labels,grid\r\n$plot = showplot($graphs,-5,5,-5,5,1,1);\r\n\r\n\/\/this question is not randomized; it's just meant for\r\n\/\/illustration of graphing options.\r\n\r\n\/\/the backslashes above add extra spacing between the\r\n\/\/limit and the f(x)\r\n\r\n$answer[0] = 5\r\n$answer[1] = -4\r\n$answer[2] = \"DNE\"\r\n$answer[3] = -1","qcontrol":"","qtext":"Dieser Graph stellt die Funktion `f(x)` dar:\r\n\r\n$plot\r\n\r\nBestimme`lim_(x-&gt;-1+0)\\ \\ f(x)`  $answerbox[0]\r\n\r\nBestimme `lim_(x-&gt;-1-0)\\ \\ f(x)`  $answerbox[1]\r\n\r\nBestimme `lim_(x-&gt;-1)\\ \\ f(x)`  $answerbox[2]\r\n\r\nBestimme `lim_(x-&gt;2)\\ \\ f(x)` $answerbox[3]","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"3":{"uniqueid":1335070150441424,"adddate":1344429111,"lastmoddate":1700433880,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"3D-Graphik Beispiel","qtype":"choices","control":"loadlibrary(\"plot3d\")\r\n\r\n$graph = spacecurve(\"[cos(t),sin(t),t]\",0,10,50)\r\n\r\n$plot = plot3d(\"x^2+y^2\",-2,2,-2,2)\r\n\r\n$questions = array(\"A\",\"B\")\r\n$answer = 0\r\n\r\n","qcontrol":"","qtext":"A: $graph\r\n\r\nB: $plot\r\n\r\nWelche dieser Abbildungen stellt eine Raumkurve dar?\r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"4":{"uniqueid":1335070313735935,"adddate":1344429111,"lastmoddate":1721815538,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Zeichenaufgabe: Zeichne x^2-a","qtype":"draw","control":"$a = rand(1,4)\r\n\r\n\/\/define grid to draw on\r\n$grid = \"-4,4,-4,16,1,1,200,450\"\r\n\/\/define answer lines\r\n$answers = \"x^2-$a\"\r\n\/\/limit to line entry\r\n$answerformat = \"twopoint,parab\"\r\n$snaptogrid=1\r\n$reltolerance=1","qcontrol":"","qtext":"\u003Cp\u003ESkizzieren Sie den Graphen von `y = x^2-$a`. Klicken Sie dazu zun\u00c3\u00a4chst auf den Scheitelpunkt, dann auf einen weiteren Punkte des Graphen f&uuml;r ganzzahlige Argumente.\u003C\/p\u003E\r\n\u003Cp style=\"text-align: center;\"\u003E$answerbox\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"6":{"uniqueid":1335070807869037,"adddate":1344429111,"lastmoddate":1344429111,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Beispiel f\u00c3\u00bcr eine berechnete Matrix (copy by Ingo dahn)","qtype":"calcmatrix","control":"\/\/if $answersize is specified, the user will be provided\n\/\/an array of boxes in which to enter their answer.  If\n\/\/not, they will be required to use ASCIIMath format for\n\/\/their answer, like ((1,2,3),(4,5,6))\n$answersize=\"2,3\"\n\n$a = rands(1,9,6)\n$b = rands(1,9,6)","qcontrol":"","qtext":"Addiere: `[ ($a[0],$a[1],$a[2]),($a[3],$a[4],$a[5]) ] + [($b[0],$b[1],$b[2]),($b[3],$b[4],$b[5])]`","answer":"\/\/load in vector functions\nloadlibrary(\"vector\")\n$c = vecsum($a,$b)\n\/\/because this is a calculated type, the user could enter\n\/\/something like 8\/2 instead of 4 and it would be fine.\n$answer = \"(($c[0],$c[1],$c[2]),($c[3],$c[4],$c[5]))\"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"8":{"uniqueid":1335295841806505,"adddate":1344429111,"lastmoddate":1661863921,"ownerid":2,"author":"Dahn,Ingo, mb Gaa,Julia, mb dahn,Ingo, mb Krawczyk,Lars","userights":3,"description":"Verw\u00c3\u00bcrfelter Beweis\r\nAus Wolter, Dahn: Analysis Individuell","qtype":"matching","control":"$questions=array(\"(1)\", \"(2)\",\"(3)\",\"(4)\",\"(5)\",\"(6)\")\r\n$answers = array(\"Sei `x in C(X uu Y)` [x in C(X uu Y)].\",\"Dann ist `x in M` [x in M] aber nicht in `X uu Y` [X uu Y]\", \"Dann ist x weder in X noch in Y\", \"Dann ist x sowohl in C(X) als auch in C(Y)\",\"Dann ist `x in C(X) nn C(Y)` [x in C(X) nn C(Y)]\",\"Deshalb ist `C(X uu Y) sube C(X) nn C(Y)` [C(X uu Y) sube C(X) nn C(Y)]\")\r\n$noshuffle=\"questions\"\r\n$displayformat=\"select\"","qcontrol":"","qtext":"F\u00c3\u00bcr alle Teilmengen `N sube M` sei `C(N)`das relative Komplement von `N` bez\u00c3\u00bcglich `M`.\r\n\r\nBestimmen Sie die richtige Reihenfolge der Zeilen des Beweises der Aussage\r\n\r\n\u003Cem\u003EF\u00c3\u00bcr alle Mengen `X,Y sube M`gilt: `C(X uu Y) sube C(X) nn C(Y)`.\u003C\/em\u003E","answer":"","hasimg":0,"extref":"read!!https:\/\/userpages.uni-koblenz.de\/~dahn\/Analysis\/CNT1_1_3.PDF!!0","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"10":{"uniqueid":1361379894175704,"adddate":1361379894,"lastmoddate":1562163536,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Conditional Question (Komposition von Funktionen)\r\nNach einer Frage von David Lippman aus der WAMAP-Bibliothek","qtype":"conditional","control":"$anstypes = \"numfunc,numfunc\"\r\n\r\n$f = $stuanswers[$thisq][0]\r\n$g = $stuanswers[$thisq][1]\r\n\r\n\/\/define the answer as an array of function comparisons\r\n\/\/in the first, we compare f composed with g to the desired result.  \r\n\/\/in the second and third, we check neither function is the identity function\r\n$answer = array(  array('function',evalfunc($f,'x',$g), '1\/(x^2+4)'), array('!function',$f,'x'), array('!function',$g,'x')  )\r\n\r\n\r\n\/\/alternatively, we could have used the comparefunctions macro directly to create our own boolean expression.  The only downside is that\r\n\/\/it won't respond to setting $abstolerance or $domain\r\n\/\/$answer = comparefunctions(evalfunc($f,'x',$g), '1\/(x^2+4)') && !comparefunctions($f,'x') && !comparefunctions($g,'x')\r\n","qcontrol":"","qtext":"\u003Cp\u003EGeben Sie zwei Funktionen f und g - beide verschieden von der identischen Funktion - an, so dass `f(g(x)) = 1\/(x^2+4)`\r\n  \u003Cbr \/\u003E\u003Cbr \/\u003E\r\n  f(x) = $answerbox[0]\r\n  \u003Cbr \/\u003E\u003Cbr \/\u003E\r\n  g(x) = $answerbox[1]\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"11":{"uniqueid":1361380543203301,"adddate":1361380543,"lastmoddate":1361381777,"ownerid":2,"author":"dahn,Ingo","userights":2,"description":"Conditional Question (Anstieg einer Funktion)\r\nvon David Lippman aus der WAMAP-Bibliothek","qtype":"conditional","control":"$anstypes = \"calculated,calculated\"\r\n\r\n$hidepreview = true\r\n$answerboxsize = 2\r\n\r\n\/\/using $stuanswersval here instead of $stuanswers to get the numerical value of the Calculated type rather than what the student typed\r\n$a = $stuanswersval[$thisq][0]\r\n$b = $stuanswersval[$thisq][1]\r\n\r\n$c,$d = nonzerodiffrands(-7,7,2)\r\n$s = randfrom(\",-\")\r\n$func = makepretty(\"$s (x-$c)^2 + $d\")\r\n\r\n\/\/test to see if b\u003Ea and f(b)\u003Ef(a), giving a positive rate of change\r\n$answer = (evalfunc($func,'x',$b) \u003E evalfunc($func,'x',$a)) && ($b\u003E$a)","qcontrol":"","qtext":"Geben Sie ein Intervall an, auf dem der mittlere Anstieg der Funktion `f(x)=$func` positiv ist.\r\n\r\n$answerbox[0] &lt; x &lt; $answerbox[1]","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"23":{"uniqueid":1391347112246960,"adddate":1391347112,"lastmoddate":1476219367,"ownerid":1233,"author":"Platz,Melanie, mb dahn,Ingo","userights":2,"description":"Aufgabe zur ersten binomischen Formel","qtype":"numfunc","control":"$variables=\"r,s,t,u,v,w\"\r\n$x=randfrom(\"u,v,w\")\r\n$y=randfrom(\"r,s,t\")\r\n$a,$b=rands(3,10,2)\r\n$term=makeprettydisp(\"($a$x+$b$y)^2\")\r\n$ans1=$a^2\r\n$ans2=2*$a*$b\r\n$ans3=$b^2\r\n$answer=\"$ans1$x^2+$ans2$x$y+$ans3$y^2\"\r\n$requiretimes=(\"$x,=2\")","qcontrol":"","qtext":"\u003Cp\u003EBerechne mit der ersten binomischen Formel!\u003C\/p\u003E\r\n\u003Cp\u003E$term = $answerbox\u003C\/p\u003E","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"12":{"uniqueid":1394371721995247,"adddate":1394371721,"lastmoddate":1700746621,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Verkettung von Funktionen, Transformation des Funktionsgraphen. Mit SAGE-Unterst\u00c3\u00bctzung in der Hilfe","qtype":"multipart","control":"$anstypes=\"numfunc,numfunc,numfunc,numfunc,numfunc\"\r\n$func=\"x^3-4*x\"\r\n$answer[0]=$func\r\n$plot=showplot($func)\r\n$answer[1]=\"x^3-4*x+1\"\r\n$answer[2]=\"(x+1)^3-4*(x+1)\"\r\n$answer[3]=\"0.5*x^3-2*x\"\r\n$answer[4]=\"(2*x)^3-8*x\"","qcontrol":"","qtext":"Hier sehen Sie den Graphen eines Polynoms 3. Grades `f(x)=px^3+qx^2+rx+s`\r\n$plot\r\n\r\na) `f(x)=` $answerbox[0]\r\n\r\nb) Verschieben des Graphen von `f` um `1` nach oben: $answerbox[1]\r\n\r\nc) Verschieben des Graphen von `f` um `1` nach links: $answerbox[2]\r\n\r\nd) Stauchen des Graphen von `f` auf halbe H\u00c3\u00b6he: $answerbox[3]\r\n\r\ne) Stauchen des Graphen von `f` auf halbe Breite: $answerbox[4]","answer":"","hasimg":0,"extref":"read!!https:\/\/netmath.vcrp.de\/downloads\/Einheiten\/AnalysisIndividuell\/addons\/05\/sageGraphTransform.html","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"2":{"uniqueid":1395321999057279,"adddate":1395321999,"lastmoddate":1597824627,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Funktionstypen aus Graph erkennen, \u00c3\u00bcbersetzt von Wamap #51848","qtype":"string","control":"$questions = listtoarray(\"Lineare Funktion,Quadratische Funktion,Exponentialfunktion,Rationale Funktion,Wurzelfunktion\")\r\n$eqns = array(\"x+1\",\"-x^2+4\",\"2^x\",\"1\/x\",\"sqrt(x)\")\r\n$r = rand(0,4)\r\n\r\n$answer = $questions[$r]\r\n\r\n$g = showplot($eqns[$r],-5,5,-5,5)\r\n$displayformat = 'typeahead'","qcontrol":"","qtext":"$g\r\n\r\nZu welcher Funktionsfamilie geh&ouml;rt dieser Graph?\r\n\r\n$answerbox","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"13":{"uniqueid":1397028299835748,"adddate":1397028299,"lastmoddate":1700757421,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"L\u00c3\u00b6se ein 3x3-System, alle Koeffizienten != 0. Mit grafischer Darstellung in Sage","qtype":"multipart","control":"$anstypes = array(\"number\",\"number\",\"number\")\r\nloadlibrary(\"matrix\")\r\n\r\n$a,$b,$c,$d,$e,$f,$g,$h,$i = nonzerorands(-6,6,9) where ($a*$e*$i+$b*$f*$g+$c*$d*$h-$g*$e*$c-$h*$f*$a-$i*$d*$b!=0)\r\n$x,$y,$z = rands(-6,6,3)\r\n\r\n$j = $a*$x+$b*$y+$c*$z\r\n$k = $d*$x+$e*$y+$f*$z\r\n$l = $g*$x+$h*$y+$i*$z\r\n\r\n$matrix=matrix(array($a,$b,$c,$j,$d,$e,$f,$k,$g,$h,$i,$l),3,4)\r\n$eq=matrixsystemdisp($matrix)\r\n\r\n$answer[0] = $x\r\n$answer[1] = $y\r\n$answer[2] = $z\r\n\r\n$answerboxsize=2\r\n\r\n$eq1=makexxpretty(\"$a*x+$b*y+$c*z-$j\")\r\n$eq2=makexxpretty(\"$d*x+$e*y+$f*z-$k\")\r\n$eq3=makexxpretty(\"$g*x+$h*y+$i*z-$l\")\r\n$baseurl_sage=\"https:\/\/netmath.vcrp.de\/downloads\/Systeme\/Sage\/LGS3Sage.html?\"\r\n$url_sage=\"$baseurl_sage\".\"eq1=\".$eq1.\"&eq2=\".$eq2.\"&eq3=\".$eq3","qcontrol":"","qtext":"L\u00c3\u00b6sen Sie das folgende Gleichungssystem. Geben Sie Ihre L\u00c3\u00b6sung in der Form `(x,y,z)` an.\r\n\r\n`$eq`\r\n\r\n`(x,y,z)=(`$answerbox[0],$answerbox[1],$answerbox[2]`)`\r\n\r\n\u003Cb\u003EEine grafische Darstellung dieses Gleichungssystems finden Sie \u003Ca href=\"$url_sage\" target=\"_blank\"\u003Ehier\u003C\/a\u003E\u003C\/b\u003E.\r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"15":{"uniqueid":1405006703014522,"adddate":1405006703,"lastmoddate":1446136125,"ownerid":189,"author":"Schell,Uli","userights":2,"description":"Berechnung von Mittelwert, Standard-Abweichung, Variationskoeffizient einer zahlenreihe(Zust.: Uli Schell #KL #AP #ST)\t","qtype":"multipart","control":"$anstypes = array(\"number\", \"number\", \"number\")\r\n$n = rand(4,6)\r\n$a = diffrrands(10,50,.1,$n)\r\n\r\n$arr = showarrays(\"x\",$a)\r\n\r\nloadlibrary(\"stats\")\r\n$abstolerance = .015\r\n$answer[0] = round(mean($a),2)\r\n$answer[1] = stdev($a)\r\n$showanswer[1] = round($answer[1],2)\r\n$answer[2] = (stdev($a))\/(mean($a))*100\r\n$showanswer[2] = round($answer[2],2)\r\n$answerboxsize = 6","qcontrol":"","qtext":"Berechnen Sie f\u00c3\u00bcr die folgende Stichprobe einer Grundgesamtheit das arithmetische Mittel, die Standardabweichung und den Variationskoeffizienten.\r\n\r\n$arr\r\n\r\nBestimmen Sie die einzelnen Werte genau und runden Sie bei den jeweiligen Eingaben auf zwei Nachkommastellen.\r\n\r\n`bar(X)=` $answerbox[0]\r\n\r\n`s=` $answerbox[1]\r\n\r\n`CV` = $answerbox[2]%","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":0,"license":1,"ancestorauthors":"Reidel,Jessica; Schraag,Andreas, mb Schell,Uli","otherattribution":"","a11yalttype":0,"a11yalt":0},"39":{"uniqueid":1406795121811981,"adddate":1406795121,"lastmoddate":1692284476,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Zahlengerade, Intervall","qtype":"string","control":"loadlibrary(\"virtmanip\")\r\n$l = rand(-10,5)\r\n$r = rand($l+1,10)\r\n\r\n$lrand=rrand(0,1,0.1)\r\nif ($lrand \u003C 0.5) {\r\n  $lendSymb = \"(\";\r\n  $lendMath=\"&lt;\";\r\n  $lendType=2;\r\n} else {\r\n  $lendSymb=\"[\";\r\n  $lendMath=\"&lt;=\";\r\n  $lendType=3;\r\n}\r\n$rrand=rrand(0,1,0.1)\r\nif ($rrand \u003C 0.5) {\r\n  $rendSymb = \")\";\r\n  $rendMath=\"&lt;\";\r\n  $rendType=2;\r\n} else {\r\n  $rendSymb=\"]\";\r\n  $rendMath=\"&lt;=\";\r\n  $rendType=3;\r\n}\r\n$listener = vmgetlistener($thisq)\r\n  $stua = $stuanswers[$thisq]\r\n  $vm = vmsetupnumberlineinterval($stua,$thisq)\r\n  $showanswer = \"($l,$r]\"\r\n  $answer = \"wrong\".$stua\r\n  if ($stua !== null && $stua != $answer) {\r\n    $scale,$leftend,$rightend,$lefttype,$righttype = vmnumberlineintervalgetvals($stua)\r\n    $answer = $stua if (($leftend == $l) && ($lefttype == $lendType) && ($rightend == $r) && ($righttype == $rendType))\r\n  } \r\n\r\n$hidetips = true","qcontrol":"","qtext":"Welches Intervall stellt `{x in RR : $l $lendMath x $rendMath $r}` dar?\r\n\r\n$vm\r\n$listener\r\n\u003Cdiv style=\"position:absolute;left:0;right:0;visibility:hidden\"\u003E$answerbox\u003C\/div\u003E \r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"19":{"uniqueid":1409573025717222,"adddate":1409573025,"lastmoddate":1700740073,"ownerid":2,"author":"dahn,Ingo, mb Dahn,Ingo","userights":2,"description":"Stetigkeit Epsilon-Delta-Definition, mit Taschenrechner, s.a. 4462, 4468, 4469, 4471","qtype":"conditional","control":"$anstypes=\"number\"\r\n$variables=\"x\"\r\n$f=\"x^3+3*x\"\r\n$min=-2\r\n$max=2\r\n$a=rrand($min,$max,0.1)\r\n$fa=evalfunc($f,\"x\",$a)\r\n\r\n$eps=rrand(0.2,0.9,0.1)\r\n\r\n$graph= showplot(array($f,\"$f,red,$a,$fa,open\"),-2,2,-14,14,\"0.2:1\",\"0.2:2\",500,500)\r\n$graph1=addlabel($graph,$a,-1,\"a\",\"red\")\r\n$graph2=addlabel($graph1,0,$fa,\"f(a)\",\"red\",\"right\")\r\n\r\n$delta=getstuans($stuanswers,$thisq,0)\r\n\r\nif($delta != null){\r\n     $ld=$a-$delta\r\n     $lld=\"$ld\"\r\n     $rd=$a+$delta\r\n     $rrd=\"$rd\"\r\n     $answer=comparefunctions(\"($eps)-abs(($f)-($fa))\",\"abs(($eps)-abs(($f)-($fa)))\",\"x\",\"|0.001\",\"$lld,$rrd\")\r\n} else {\r\n  $answer=0\r\n}\r\n","qcontrol":"","qtext":"Es sei `f(x) = $f`, \r\n\r\n`a = $a`, `\\varepsilon = $eps`.\r\n\r\n$graph2 [EMBED:https:\/\/www.wamap.org\/scicalc.html,320,230,false] \r\n\r\nGeben Sie ein `\\delta &gt; 0` an, so dass f\u00c3\u00bcr alle `x in (a - \\delta, a + \\delta)` der Wert von `|f(x)-f(a)| &lt; \\varepsilon` ist.\r\n\r\n\r\n$answerbox[0]\r\n\r\n\u003Cb\u003ETip:\u003C\/b\u003E Der Taschenrechner kann auch komplizierte Ausdr\u00c3\u00bccke verarbeiten!\r\n\r\n","answer":"","hasimg":0,"extref":"","deleted":0,"broken":0,"replaceby":0,"solution":"","solutionopts":6,"license":1,"ancestorauthors":"","otherattribution":"","a11yalttype":0,"a11yalt":0},"25":{"uniqueid":1394832193830900,"adddate":1428521488,"lastmoddate":1518517319,"ownerid":2,"author":"Coe,Ted, mb Lippman,David, mb dahn,Ingo","userights":2,"description":"Geogebra Multiplikation","qtype":"multipart","control":"$anstypes = \"string,number\"\r\nloadlibrary(\"geogebra\")\r\n$a = rand(2,3)*nonzerorand(-1,1)\r\n$b = rand(2,4)*nonzerorand(-1,1)\r\n$hidetips = true\r\n\r\n\/\/We want to initialize the Geogebra applet to the student's last answer, so we'll look what was recorded.\r\n\/\/if nothing, we'll initialize to zero, othersize we'll use what they provided\r\n$stu = getstuans($stuanswers,$thisq,0)\r\nif ($stu==null) {\r\n  $ia = 0\r\n  $ib = 0\r\n} else {\r\n  $ia,$ib = explode(\",\",$stu)\r\n}\r\n\r\n\/\/this is the ggbbase64 data from the html5 export of the Geogebra file\r\n$geogebracode = \"UEsDBBQACAgIAE9Q3UYAAAAAAAAAAAAAAAAWAAAAZ2VvZ2VicmFfamF2YXNjcmlwdC5qc0srzUsuyczPU0hPT\/LP88zLLNHQVKiu5QIAUEsHCEXM3l0aAAAAGAAAAFBLAwQUAAgICABPUN1GAAAAAAAAAAAAAAAAFwAAAGdlb2dlYnJhX2RlZmF1bHRzMmQueG1s7ZpfU+M2EMCf7z6Fxk\/tA4ntxElgCDfczXTKDMd1CnPTV8XeOCqy5EoycfLpT5b8L5DQYDgy0L5grSLJq9\/uSiuZ0095QtEdCEk4mzpez3UQsJBHhMVTJ1Pzo4nz6ezjaQw8hpnAaM5FgtXUCYqWdT8t9Tz\/uKhDuSQnjF\/hBGSKQ7gOF5DgSx5iZZoulEpP+v3lctmrBu1xEffjWPVyGTlIK8Tk1CkLJ3q4jU7LgWnuu67X\/+vrpR3+iDCpMAvBQVrZCOY4o0rqIlBIgCmkVilMnZTTVcyZgyieAZ06f1Ry2WPqjF3n7OOHU0oYXKsVBaQWJLxlILVGvlMO49rC7ySKoIDm9Is+csGXiM\/+hlCPo0QG9WuMYNron79wygUSulswcJCGHHgOmplBMU0XWJd65YgUr0CgO0yLX8saPeBXHoGtHdpazEhi6CKpIC0UQjIFiEypVjnVwxmrzjGVRp\/TfolnK6iCwQYpW9Gg8l4NlWtAuQ84uYfmNM9YWAx49R2Leg4so7TFaRQ4XebsB8GOWY+DQ0875YSplm9oCf0yFwC\/tubtuZ3m3ba1YfATre1tm\/aH05BzEUmUT50rfOWgVflc26dpYghck3X5ykG71gRDo98TMUaQAtPBojZYep1YjiYGZvGY2cf7hUmJbFheGqHBN9jii1bHfZzRc+8H4ZH3WmtPtwV2P6JH3pP981t7s\/T8Tl7p+XZlM8\/\/ZJRfsD8hJhuJhzf4n2UnlpseOXzHe45pYlnJ4u\/UCXmSUshfELCEuJBqXteVXCP2u21FB07h9gLcZaXlmaLFuy6Y0ochMNmgtCq3Xn4LkN7ozt\/YjcBMFoco26aC9di+1krDLzdTcP\/5KdZ7sgX8wzbCg+joICFR\/wKYh5lsCFupRjx5o4hxlhNKsFg98MWnk3